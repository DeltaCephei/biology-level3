    }
    .quiz-q__feedback--correct { background: rgba(0, 255, 136, 0.08); border: 1px solid rgba(0, 255, 136, 0.2); }
    .quiz-q__feedback--incorrect { background: rgba(255, 110, 199, 0.08); border: 1px solid rgba(255, 110, 199, 0.2); }
    .quiz-results { text-align: center; padding: var(--space-5); }
    .quiz-score-ring {
      position: relative;
      width: 120px;
      height: 120px;
      margin: 0 auto var(--space-4);
    }
    .score-svg { width: 100%; height: 100%; }
    .score-text {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--fluoro-cyan);
    }
    .score-label {
      font-size: 0.92rem;
      color: var(--text-secondary);
      margin-bottom: var(--space-4);
    }

    /* ── Sidebar ── */
    .week-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
    .sidebar-card {
      background: var(--surface-1);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .sidebar-card h3 {
      font-size: var(--text-base);
      font-weight: var(--weight-semibold);
      margin-bottom: var(--space-4);
      color: var(--text-primary);
    }
    .sidebar-card--connection { border-left: 3px solid var(--fluoro-cyan); }
    .sidebar-card--nav { border: 1px solid var(--accent); background: var(--surface-2); }

    /* ── Lesson Navigator ── */
    .lesson-nav {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .lesson-nav__item {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      background: var(--surface-3);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      text-decoration: none;
      transition: all var(--transition-fast);
    }
    .lesson-nav__item:hover {
      border-color: var(--accent);
      transform: translateX(4px);
    }
    .lesson-nav__item:link, .lesson-nav__item:visited { color: inherit; }
    .lesson-nav__number {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 700;
    }
    .lesson-nav__item--1 .lesson-nav__number {
      background: rgba(0, 200, 255, 0.15);
      color: var(--fluoro-cyan);
      border: 1px solid rgba(0, 200, 255, 0.3);
    }
    .lesson-nav__item--2 .lesson-nav__number {
      background: rgba(0, 255, 136, 0.15);
      color: var(--green-vivid);
      border: 1px solid rgba(0, 255, 136, 0.3);
    }
    .lesson-nav__info { display: flex; flex-direction: column; gap: 2px; }
    .lesson-nav__title {
      font-family: var(--font-display);
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      color: var(--text-primary);
    }
    .lesson-nav__desc {
      font-size: var(--text-xs);
      color: var(--text-muted);
    }
    .sidebar-text {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
      margin-bottom: var(--space-2);
    }
    .sidebar-text--highlight { color: var(--accent); font-weight: var(--weight-medium); }
    .objectives-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .objective-item {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
    }
    .objective-checkbox {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      margin-top: 2px;
      border: 1.5px solid var(--border-default);
      border-radius: var(--radius-sm);
      background: var(--surface-2);
      transition: border-color var(--transition-fast);
    }
    .objective-item:hover .objective-checkbox { border-color: var(--accent); }
    .vocab-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
    .vocab-chip {
      padding: var(--space-2) var(--space-4);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-full);
      font-size: var(--text-sm);
      font-family: var(--font-body);
      color: var(--text-secondary);
      transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
    }
    .vocab-chip:hover { background: var(--accent-muted); border-color: var(--accent); color: var(--accent); }
    .sidebar-links { display: flex; flex-direction: column; gap: var(--space-2); }
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      background: var(--surface-2);
      border-radius: var(--radius-md);
      text-decoration: none;
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--text-primary);
      transition: background var(--transition-fast), transform var(--transition-fast);
    }
    .sidebar-link:hover { background: var(--surface-3); transform: translateX(4px); }
    .sidebar-link__icon { flex-shrink: 0; display: flex; align-items: center; }
    .week-sidebar .sidebar-card:nth-child(1) { transition-delay: 0.1s; }
    .week-sidebar .sidebar-card:nth-child(2) { transition-delay: 0.15s; }
    .week-sidebar .sidebar-card:nth-child(3) { transition-delay: 0.2s; }
    .week-sidebar .sidebar-card:nth-child(4) { transition-delay: 0.25s; }
    .week-sidebar .sidebar-card:nth-child(5) { transition-delay: 0.3s; }
    .week-sidebar .sidebar-card:nth-child(6) { transition-delay: 0.35s; }
    .week-sidebar .sidebar-card:nth-child(7) { transition-delay: 0.4s; }

    /* ── Migration Badge (reused from Week 5) ── */
    .migration-badge {
      font-size: 0.75rem;
      font-weight: 600;
      font-family: var(--font-display);
      padding: var(--space-1) var(--space-3);
      border-radius: 999px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      white-space: nowrap;
    }
    .migration-badge--seasonal { background: rgba(0,200,255,0.12); color: var(--fluoro-cyan); border: 1px solid rgba(0,200,255,0.25); }
    .migration-badge--breeding { background: rgba(0,255,136,0.12); color: var(--green-vivid); border: 1px solid rgba(0,255,136,0.25); }

    /* ── Showcase Card Latin / Scientific (reused) ── */
    .showcase-card__latin { color: var(--text-muted); font-weight: 400; font-size: 0.9rem; }
    .showcase-card__scientific { font-size: 0.82rem; color: var(--text-muted); }

    /* ── Looking Ahead ── */
    .looking-ahead-box {
      background: linear-gradient(135deg, rgba(0, 200, 255, 0.06), rgba(0, 255, 136, 0.04));
      border: 1px solid rgba(0, 200, 255, 0.2);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      margin-top: var(--space-6);
    }
    .looking-ahead-box h3 {
      font-family: var(--font-display);
      color: var(--fluoro-cyan);
      margin-bottom: var(--space-3);
    }

    /* ==========================================================================
       Week 6 Custom Components — Lesson 2
       ========================================================================== */

    /* ── Inline Lesson Navigation ── */
    .lesson-inline-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      margin-bottom: var(--space-5);
    }
    .lesson-inline-nav--bottom {
      margin-bottom: 0;
      margin-top: var(--space-6);
    }
    .lesson-inline-nav__current {
      font-size: var(--text-xs);
      font-weight: var(--weight-semibold);
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .lesson-inline-nav__link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--accent);
      text-decoration: none;
      transition: color var(--transition-fast), transform var(--transition-fast);
    }
    .lesson-inline-nav__link:hover {
      color: var(--green-vivid);
    }
    .lesson-inline-nav__link--prev:hover {
      transform: translateX(-3px);
    }
    .lesson-inline-nav__link--next:hover {
      transform: translateX(3px);
    }
    @media (max-width: 560px) {
      .lesson-inline-nav { flex-direction: column; gap: var(--space-2); text-align: center; }
    }

    /* ── Support Box (extra scaffolding for students who need it) ── */
    .support-box {
      background: linear-gradient(135deg, rgba(0, 200, 255, 0.05), rgba(0, 255, 136, 0.03));
      border: 1px solid rgba(0, 200, 255, 0.15);
      border-left: 4px solid var(--fluoro-cyan);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin: var(--space-5) 0;
    }
    .support-box h4 {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--fluoro-cyan);
      margin: 0 0 var(--space-3);
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }
    .support-box h4::before {
      content: '💡';
      font-size: 1.1rem;
    }
    .support-box p {
      margin: 0;
      font-size: var(--text-sm);
      line-height: var(--leading-relaxed);
    }

    /* ── Stat Comparison Grid ── */
    .stat-comparison {
      margin: var(--space-5) 0;
    }
    .stat-comparison h4 {
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--text-primary);
      margin-bottom: var(--space-4);
    }
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-3);
    }
    @media (max-width: 768px) {
      .stat-grid { grid-template-columns: repeat(2, 1fr); }
    }
    .stat-card {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      padding: var(--space-4);
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .stat-card__value {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--green-vivid);
    }
    .stat-card__label {
      font-size: var(--text-xs);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
    }

    /* ── Fuel Comparison Diagram ── */
    .fuel-comparison {
      margin: var(--space-5) 0;
      overflow-x: auto;
    }
    .fuel-svg {
      width: 100%;
      max-width: 700px;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    /* ── Numbered Reasons ── */
    .numbered-reasons {
      counter-reset: reason;
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
    .numbered-reasons li {
      position: relative;
      padding-left: 2.5rem;
      font-size: var(--text-sm);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
    }
    .numbered-reasons li::before {
      counter-increment: reason;
      content: counter(reason);
      position: absolute;
      left: 0;
      top: 0;
      width: 28px;
      height: 28px;
      background: var(--surface-3);
      border: 1px solid var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--accent);
    }

    /* ── Remodelling Grid (flight muscle cards) ── */
    .remodelling-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
      margin: var(--space-5) 0;
    }
    @media (max-width: 768px) {
      .remodelling-grid { grid-template-columns: 1fr; }
    }
    .remodel-card {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      transition: border-color var(--transition-fast), transform var(--transition-fast);
    }
    .remodel-card:hover {
      border-color: var(--border-default);
      transform: translateY(-2px);
    }
    .remodel-card__icon {
      margin-bottom: var(--space-3);
    }
    .remodel-card h5 {
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--text-primary);
      margin: 0 0 var(--space-2);
    }
    .remodel-card p {
      font-size: var(--text-sm);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      margin: 0;
    }

    /* ── Organ Remodelling Diagram ── */
    .organ-diagram {
      margin: var(--space-5) 0;
      overflow-x: auto;
    }
    .organ-svg {
      width: 100%;
      max-width: 700px;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    /* ==========================================================================
       Week 6 Custom Components — Lesson 1
       ========================================================================== */

    /* ── Pathway Diagram ── */
    .pathway-diagram {
      margin: var(--space-5) 0;
      overflow-x: auto;
    }
    .pathway-svg {
      width: 100%;
      max-width: 800px;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    /* ── Hormone Timeline ── */
    .hormone-timeline {
      position: relative;
      margin: var(--space-6) 0;
      padding-left: 2.5rem;
    }
    .hormone-timeline::before {
      content: '';
      position: absolute;
      left: 12px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--fluoro-cyan), var(--green-vivid), var(--fluoro-pink), var(--accent));
      opacity: 0.4;
    }
    .timeline-phase {
      position: relative;
      margin-bottom: var(--space-6);
      padding-left: 1.5rem;
    }
    .timeline-marker {
      position: absolute;
      left: -2.5rem;
      top: 4px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      border: 2px solid;
      background: var(--surface-2);
      z-index: 1;
    }
    .timeline-marker--1 { border-color: var(--fluoro-cyan); }
    .timeline-marker--2 { border-color: var(--green-vivid); }
    .timeline-marker--3 { border-color: var(--fluoro-pink); }
    .timeline-marker--4 { border-color: var(--accent); }
    .timeline-marker::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }
    .timeline-marker--1::after { background: var(--fluoro-cyan); }
    .timeline-marker--2::after { background: var(--green-vivid); }
    .timeline-marker--3::after { background: var(--fluoro-pink); }
    .timeline-marker--4::after { background: var(--accent); }
    .timeline-content h4 {
      font-family: var(--font-display);
      font-size: 1.1rem;
      color: var(--text-primary);
      margin: 0 0 var(--space-1);
    }
    .timeline-timing {
      font-size: var(--text-sm);
      color: var(--text-muted);
      font-style: italic;
      margin: 0 0 var(--space-3);
    }

    /* ── Experiment Card ── */
    .experiment-card {
      background: var(--surface-2);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin: var(--space-5) 0;
    }
    .experiment-card h4 {
      font-family: var(--font-display);
      font-size: 1.15rem;
      color: var(--fluoro-cyan);
      margin: 0 0 var(--space-4);
    }
    .experiment-card h5 {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--text-primary);
      margin: var(--space-4) 0 var(--space-2);
    }
    .experiment-setup {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: var(--space-5);
      align-items: start;
    }
    .funnel-svg { width: 100%; height: auto; }
    @media (max-width: 768px) {
      .experiment-setup { grid-template-columns: 1fr; }
      .funnel-diagram { max-width: 200px; margin: 0 auto; }
    }

    /* ── Case Study Cards ── */
    .case-study-card {
      background: var(--surface-2);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin: var(--space-5) 0;
    }
    .case-study-card__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-4) var(--space-5);
      background: var(--surface-3);
      border-bottom: 1px solid var(--border-subtle);
    }
    .case-study-card__species h4 {
      font-family: var(--font-display);
      font-size: 1.1rem;
      color: var(--text-primary);
      margin: 0;
    }
    .case-study-card__body {
      padding: var(--space-5);
    }
    .case-study-card__body h5 {
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--text-primary);
      margin: var(--space-4) 0 var(--space-3);
    }
    .case-study-card__body h5:first-child { margin-top: 0; }
    .case-study-card__highlight {
      background: var(--surface-3);
      border-left: 3px solid var(--fluoro-cyan);
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
      padding: var(--space-4);
      margin: var(--space-4) 0;
    }
    .case-study-card__highlight h5 { color: var(--fluoro-cyan); margin-top: 0; }

    /* ── Scholarship Extension ── */
    .scholarship-extension {
      background: var(--surface-2);
      border: 1px solid var(--purple-deep);
      border-left: 4px solid var(--purple-deep);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin: var(--space-5) 0;
    }
    .scholarship-extension h4 {
      font-family: var(--font-display);
      color: var(--purple-light);
      margin: var(--space-4) 0 var(--space-3);
    }

    /* ── Audio Buttons ── */
    .section-header-with-audio {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }
    .section-header-with-audio h2,
    .section-header-with-audio h3 {
      margin-bottom: 0;
    }
    .audio-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 2px solid var(--border-default);
      background: var(--surface-2);
      font-size: 1.1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--text-secondary);
    }
    .audio-btn:hover {
      border-color: var(--accent);
      background: rgba(0, 255, 136, 0.1);
      transform: scale(1.1);
    }
    .audio-btn.playing {
      border-color: var(--accent);
      background: var(--accent);
      color: var(--surface-1);
      animation: audio-pulse 1.5s ease-in-out infinite;
    }
    @keyframes audio-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(0, 255, 136, 0.4); }
      50% { box-shadow: 0 0 0 8px rgba(0, 255, 136, 0); }
    }

    /* ── Video Embed ── */
    .video-wrapper {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      margin: var(--space-4) 0 var(--space-6);
      border-radius: var(--radius-lg);
      overflow: hidden;
      background: var(--surface-2);
    }
    .video-wrapper iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }

    /* ── Threshold Model Diagram ── */
    .threshold-model {
      background: var(--surface-2);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin: var(--space-5) 0;
      border: 1px solid var(--border-subtle);
    }
    .threshold-model h4 {
      margin-bottom: var(--space-3);
      color: var(--text-primary);
    }
    .threshold-diagram {
      margin-bottom: var(--space-4);
    }
    .threshold-svg {
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
      display: block;
    }

    /* ── Activity Card ── */
    .activity-card {
      background: var(--surface-2);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin: var(--space-5) 0;
      border: 1px solid var(--border-subtle);
      border-left: 4px solid var(--fluoro-cyan);
    }
    .activity-card h4 {
      margin-bottom: var(--space-3);
      color: var(--fluoro-cyan);
    }
    .concept-map-terms {
      margin: var(--space-4) 0;
    }

    /* ── Info Card Evidence Text ── */
    .info-card__evidence {
      font-size: var(--text-sm);
      color: var(--text-muted);
      border-top: 1px solid var(--border-subtle);
      padding-top: var(--space-3);
      margin-top: var(--space-3);
    }

    /* ==========================================================================
       Week 6 Custom Components — Lesson 4: Human Impacts
       ========================================================================== */

    /* ── Cascade Diagram ── */
    .cascade-diagram {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      margin: var(--space-5) 0;
    }
    .cascade-intro {
      margin-bottom: var(--space-4);
      font-style: italic;
      color: var(--text-secondary);
    }
    .cascade-steps {
      display: flex;
      flex-direction: column;
