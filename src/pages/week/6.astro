  <!-- Fade-in observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
  </script>

  <!-- Reveal buttons -->
  <script is:inline>
    document.querySelectorAll('.reveal-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const content = btn.nextElementSibling;
        if (!content) return;
        const isHidden = content.hidden;
        content.hidden = !isHidden;
        btn.textContent = isHidden ? 'Hide Model Answers' : 'Show Model Answers';
      });
    });
  </script>

  <!-- Quiz Engine -->
  <script is:inline>
  (function() {
    const questions = [
      {
        q: 'What is the primary environmental cue that triggers migration in most bird species?',
        opts: ['Temperature drop', 'Photoperiod (day length)', 'Rainfall pattern', 'Food scarcity'],
        correct: 1,
        explanation: 'Photoperiod is the most reliable environmental cue because it changes predictably each year, unlike temperature which fluctuates unpredictably.'
      },
      {
        q: 'Which gland secretes melatonin?',
        opts: ['Pituitary gland', 'Adrenal gland', 'Pineal gland', 'Thyroid gland'],
        correct: 2,
        explanation: 'The pineal gland secretes melatonin during darkness. The duration of the melatonin pulse encodes day length information.'
      },
      {
        q: 'What does "Zugunruhe" refer to?',
        opts: ['Pre-migratory fat deposition', 'Migratory restlessness', 'Post-migratory recovery', 'Navigation calibration'],
        correct: 1,
        explanation: 'Zugunruhe is the German term for migratory restlessness — the intense agitation and directional orientation shown by birds immediately before departure.'
      },
      {
        q: 'In Gwinner\'s constant-condition experiment, warblers showed circannual cycles of approximately:',
        opts: ['Exactly 12 months', '10–11 months', '14–15 months', '6 months'],
        correct: 1,
        explanation: 'The free-running circannual rhythm was ~10–11 months, demonstrating an endogenous clock that needs photoperiod as a Zeitgeber to stay calibrated to 12 months.'
      },
      {
        q: 'What is "hyperphagia"?',
        opts: ['Excessive sleeping before migration', 'Dramatic increase in food intake before migration', 'Shrinkage of digestive organs', 'Increase in flight muscle mass'],
        correct: 1,
        explanation: 'Hyperphagia is the period of dramatically increased food intake that allows migrants to rapidly deposit fat reserves before departure.'
      },
      {
        q: 'Why do kuaka shrink their digestive organs before migration?',
        opts: ['To make room for larger flight muscles', 'To reduce dead weight during non-stop flight', 'Because hormones damage the organs', 'To conserve water during the journey'],
        correct: 1,
        explanation: 'Since kuaka don\'t eat during their 12,000 km non-stop flight, digestive organs are unnecessary weight. Reducing mass lowers the energy cost of flight and increases range.'
      },
      {
        q: 'What is the role of corticosterone in pre-migratory physiology?',
        opts: ['It triggers gonadal growth', 'It produces melatonin', 'It mobilises fat reserves and drives hyperphagia', 'It controls the direction of migration'],
        correct: 2,
        explanation: 'Corticosterone is the main glucocorticoid in birds. It mobilises fat reserves, increases foraging intensity, and triggers hyperphagia during the pre-migratory period.'
      },
      {
        q: 'A "Zeitgeber" is best described as:',
        opts: ['An internal biological clock', 'An external cue that synchronises a biological clock', 'A hormone that triggers migration', 'A genetic mutation affecting migration timing'],
        correct: 1,
        explanation: 'Zeitgeber (German: "time-giver") is an environmental cue — primarily photoperiod — that entrains (synchronises) an endogenous biological clock to the external calendar.'
      },
      {
        q: 'Fat provides approximately how much more energy per gram than carbohydrate?',
        opts: ['1.5 times more', '2.3 times more', '3.5 times more', '5 times more'],
        correct: 1,
        explanation: 'Fat provides 39 kJ/g compared to carbohydrate\'s 17 kJ/g — approximately 2.3 times more energy per gram. This makes fat far superior as a fuel for weight-critical endurance flight.'
      },
      {
        q: 'Which of the following is NOT a reason why migratory birds primarily burn fat during flight?',
        opts: ['Fat has higher energy density than carbohydrate', 'Fat produces metabolic water when oxidised', 'Fat requires less oxygen to burn than carbohydrate', 'Fat is stored without water (anhydrously)'],
        correct: 2,
        explanation: 'Fat actually requires MORE oxygen per unit of energy than carbohydrate (RQ of 0.7 vs 1.0). This is the "oxygen paradox" of migration. The other three statements are correct advantages of fat as a migration fuel.'
      },
      {
        q: 'Before migration, kuaka digestive organs shrink by approximately:',
        opts: ['10–15%', '20–25%', '40–50%', '70–80%'],
        correct: 2,
        explanation: 'Kuaka digestive organs (stomach, intestines, liver) shrink by 40–50%. Since the bird doesn\'t eat during non-stop transoceanic flight, these organs are dead weight. The mass saved reduces the energy cost of flight.'
      },
      {
        q: 'What is the primary role of increased myoglobin in pre-migratory flight muscles?',
        opts: ['Store more fat within the muscle', 'Increase oxygen storage and delivery to mitochondria', 'Protect against lactic acid build-up', 'Increase muscle fibre thickness'],
        correct: 1,
        explanation: 'Myoglobin is an oxygen-binding protein in muscle tissue (similar to haemoglobin in blood). Increased myoglobin allows flight muscles to store and deliver more oxygen to mitochondria, sustaining the aerobic fat metabolism needed for continuous flight.'
      }
    ];

    let currentQ = 0, score = 0, answered = false;

    const startEl    = document.getElementById('trig-quiz-start');
    const startBtn   = document.getElementById('trig-quiz-start-btn');
    const activeEl   = document.getElementById('trig-quiz-active');
    const resultsEl  = document.getElementById('trig-quiz-results');
    const container  = document.getElementById('trig-q-container');
    const nextBtn    = document.getElementById('trig-q-next');
    const currentSpan= document.getElementById('trig-q-current');
    const totalSpan  = document.getElementById('trig-q-total');
    const fillBar    = document.getElementById('trig-q-fill');
    const scoreCircle= document.getElementById('trig-score-circle');
    const scoreText  = document.getElementById('trig-score-text');
    const scoreLabel = document.getElementById('trig-score-label');
    const restartBtn = document.getElementById('trig-quiz-restart-btn');

    if (!startBtn) return;

    function renderQuestion() {
      const q = questions[currentQ];
      answered = false;
      nextBtn.hidden = true;
      currentSpan.textContent = currentQ + 1;
      totalSpan.textContent = questions.length;
      fillBar.style.width = ((currentQ) / questions.length * 100) + '%';

      let html = '<div class="quiz-q"><p class="quiz-q__text">' + q.q + '</p><div class="quiz-q__options">';
      q.opts.forEach((opt, i) => {
        html += '<label class="mcq-option"><input type="radio" name="trig-q" value="' + i + '"><span class="mcq-option__text">' + opt + '</span></label>';
      });
      html += '</div><div class="quiz-q__feedback" hidden></div></div>';
      container.innerHTML = html;

      container.querySelectorAll('input[name="trig-q"]').forEach(radio => {
        radio.addEventListener('change', () => {
          if (answered) return;
          answered = true;
          const selected = parseInt(radio.value);
          const correct = q.correct;
          const labels = container.querySelectorAll('.mcq-option');
          labels.forEach((label, j) => {
            if (j === correct) label.classList.add('mcq-option--correct');
            if (j === selected && selected !== correct) label.classList.add('mcq-option--incorrect');
            label.querySelector('input').disabled = true;
          });
          if (selected === correct) score++;
          const fb = container.querySelector('.quiz-q__feedback');
          fb.hidden = false;
          fb.innerHTML = (selected === correct ? '<strong>Correct!</strong> ' : '<strong>Not quite.</strong> ') + q.explanation;
          fb.className = 'quiz-q__feedback quiz-q__feedback--' + (selected === correct ? 'correct' : 'incorrect');
          nextBtn.hidden = false;
        });
      });
    }

    startBtn.addEventListener('click', () => {
      startEl.hidden = true;
      activeEl.hidden = false;
      currentQ = 0;
      score = 0;
      renderQuestion();
    });

    nextBtn.addEventListener('click', () => {
      currentQ++;
      if (currentQ < questions.length) {
        renderQuestion();
      } else {
        activeEl.hidden = true;
        resultsEl.hidden = false;
        const pct = Math.round(score / questions.length * 100);
        const offset = 264 - (264 * pct / 100);
        scoreCircle.style.transition = 'stroke-dashoffset 1s ease';
        scoreCircle.style.strokeDashoffset = offset;
        scoreText.textContent = pct + '%';
        scoreLabel.textContent = score + ' / ' + questions.length + ' correct';
        fillBar.style.width = '100%';
      }
    });

    restartBtn.addEventListener('click', () => {
      resultsEl.hidden = true;
      startEl.hidden = false;
      currentQ = 0;
      score = 0;
      fillBar.style.width = '0%';
      scoreCircle.style.strokeDashoffset = 264;
    });
  })();
  </script>

