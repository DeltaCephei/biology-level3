  <!-- AI Marking for Scholarship question -->
  <script is:inline>
  (function() {
    const submitBtn = document.getElementById('schol-submit-btn');
    const textarea  = document.getElementById('schol-answer');
    const loading   = document.getElementById('schol-loading');
    const feedback  = document.getElementById('schol-feedback');
    const errorEl   = document.getElementById('schol-error');
    if (!submitBtn || !textarea) return;

    const RATE_KEY = 'bio_ai_mark_count';
    const RATE_DATE = 'bio_ai_mark_date';
    const MAX_PER_DAY = 10;

    function checkRate() {
      const today = new Date().toDateString();
      const stored = localStorage.getItem(RATE_DATE);
      if (stored !== today) {
        localStorage.setItem(RATE_DATE, today);
        localStorage.setItem(RATE_KEY, '0');
        return true;
      }
      const count = parseInt(localStorage.getItem(RATE_KEY) || '0');
      return count < MAX_PER_DAY;
    }

    function incrementRate() {
      const count = parseInt(localStorage.getItem(RATE_KEY) || '0');
      localStorage.setItem(RATE_KEY, String(count + 1));
    }

    submitBtn.addEventListener('click', async () => {
      const answer = textarea.value.trim();
      if (!answer || answer.split(/\s+/).length < 30) {
        errorEl.hidden = false;
        errorEl.textContent = 'Please write at least 30 words before submitting.';
        return;
      }
      if (!checkRate()) {
        errorEl.hidden = false;
        errorEl.textContent = 'Daily limit reached (10 submissions per day). Try again tomorrow.';
        return;
      }

      loading.hidden = false;
      feedback.hidden = true;
      errorEl.hidden = true;
      submitBtn.disabled = true;

      try {
        const res = await fetch('https://psychology-ai-marker.deornorth.workers.dev', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            subject: 'biology',
            level: 'scholarship',
            question: 'Some populations of blackcap warbler (Sylvia atricapilla) in central Europe have shifted their migratory direction from southwest (towards Africa) to northwest (towards Britain) in approximately 50 years. Propose a biological explanation for how this rapid change in migratory behaviour could occur, integrating physiological, genetic, and epigenetic mechanisms, and addressing the role of natural selection.',
            answer: answer,
            markSchedule: 'Scholarship Biology — Migratory behaviour: physiological triggers, HPG axis, clock genes, epigenetic mechanisms, natural selection'
          })
        });

        if (!res.ok) throw new Error('Server error: ' + res.status);
        const data = await res.json();
        feedback.hidden = false;
        feedback.innerHTML = data.feedback || data.response || 'Feedback received.';
        incrementRate();
      } catch (e) {
        errorEl.hidden = false;
        errorEl.textContent = 'Could not connect to the marking service. Please try again later.';
      } finally {
        loading.hidden = true;
        submitBtn.disabled = false;
      }
    });
  })();
  </script>

