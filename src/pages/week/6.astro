  <!-- Copy All Answers -->
  <script is:inline>
  (function() {
    const copyBtn = document.getElementById('copy-all');
    const copyFb  = document.getElementById('copy-feedback');
    if (!copyBtn) return;

    copyBtn.addEventListener('click', async () => {
      const nameEl = document.getElementById('student-name');
      const name = nameEl?.value || 'Not provided';

      let text = 'MIGRATION PHYSIOLOGY (Week 6, Lessons 1 & 2)\n';
      text += 'Name: ' + name + '\n';
      text += 'Date: ' + new Date().toLocaleDateString('en-NZ') + '\n';
      text += '==================================================\n\n';

      document.querySelectorAll('[data-answer]').forEach(input => {
        const id = input.getAttribute('data-answer') || '';
        const qText = input.closest('.question-card')?.querySelector('.question-text')?.textContent?.trim() || '';
        const label = 'Q' + id;
        let value = '';
        if (input instanceof HTMLTextAreaElement || input instanceof HTMLInputElement) {
          value = input.value;
        }
        text += label + (qText ? ' — ' + qText.substring(0, 80) + (qText.length > 80 ? '…' : '') : '') + '\n';
        text += 'Answer: ' + (value || '(not answered)') + '\n\n';
      });

      // Also grab scholarship answer
      const scholTa = document.getElementById('schol-answer');
      if (scholTa && scholTa.value.trim()) {
        text += 'Q7 (Scholarship)\n';
        text += 'Answer: ' + scholTa.value + '\n\n';
      }

      try {
        await navigator.clipboard.writeText(text);
        if (copyFb) { copyFb.hidden = false; setTimeout(() => { copyFb.hidden = true; }, 2200); }
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.cssText = 'position:fixed;opacity:0;';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        if (copyFb) { copyFb.hidden = false; setTimeout(() => { copyFb.hidden = true; }, 2200); }
      }
    });
  })();
  </script>

  <!-- Audio player for AI Me narrations -->
  <script is:inline>
  (function initWeek6Audio() {
    var audioMap = {
      'lesson1-intro-audio': '/audio/week6_lesson1_intro.mp3',
      'photoperiod-audio': '/audio/week6_photoperiod.mp3',
      'zugunruhe-audio': '/audio/week6_zugunruhe.mp3',
      'nz-cases-audio': '/audio/week6_nz_cases.mp3',
      'hyperphagia-audio': '/audio/week6_hyperphagia_fuel.mp3',
      'remodelling-audio': '/audio/week6_body_remodel.mp3',
      'lesson3-intro-audio': '/audio/week6_evolution_intro.mp3',
      'partial-migration-audio': '/audio/week6_partial_migration.mp3',
      'blackcap-audio': '/audio/week6_blackcap_experiments.mp3',
      'migration-genes-audio': '/audio/week6_migration_genes.mp3',
      'nz-evolution-audio': '/audio/week6_nz_evolution.mp3',
      'kuaka-flight-audio': '/audio/week6_kuaka_flight.mp3',
      'lesson4-intro-audio': '/audio/week6_lesson4_intro.mp3',
      'mismatch-audio': '/audio/week6_mismatch.mp3',
      'polar-ice-audio': '/audio/week6_polar_ice.mp3',
      'habitat-loss-audio': '/audio/week6_habitat_loss.mp3',
      'light-pollution-audio': '/audio/week6_light_pollution.mp3',
      'other-threats-audio': '/audio/week6_other_threats.mp3',
      'adaptation-audio': '/audio/week6_adaptation_limits.mp3'
    };

    var currentAudio = null;
    var currentBtn = null;

    function stopCurrent() {
      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        currentAudio = null;
      }
      if (currentBtn) {
        currentBtn.textContent = '\u25B6';
        currentBtn.classList.remove('playing');
        currentBtn = null;
      }
    }

    Object.keys(audioMap).forEach(function(id) {
      var btn = document.getElementById(id);
      if (!btn) return;

      btn.addEventListener('click', function() {
        // If this button is already playing, pause it
        if (currentBtn === btn && currentAudio && !currentAudio.paused) {
          currentAudio.pause();
          btn.textContent = '\u25B6';
          btn.classList.remove('playing');
          return;
        }

        // If this button was paused mid-way, resume
        if (currentBtn === btn && currentAudio && currentAudio.paused && currentAudio.currentTime > 0) {
          currentAudio.play();
          btn.textContent = '\u23F8\uFE0E';
          btn.classList.add('playing');
          return;
        }

        // Stop any other playing audio
        stopCurrent();

        // Start fresh
        var audio = new Audio(audioMap[id]);
        currentAudio = audio;
        currentBtn = btn;

        btn.textContent = '\u23F8\uFE0E';
        btn.classList.add('playing');
        audio.play();

        audio.addEventListener('ended', function() {
          btn.textContent = '\u25B6';
          btn.classList.remove('playing');
          if (currentAudio === audio) { currentAudio = null; currentBtn = null; }
        });

        audio.addEventListener('error', function() {
          btn.textContent = '\u25B6';
          btn.classList.remove('playing');
          if (currentAudio === audio) { currentAudio = null; currentBtn = null; }
        });
      });
    });
  })();
  </script>

  <!-- Lesson 4: Polar Ice Map Slider -->
  <script is:inline>
  (function initPolarMaps() {
    var slider = document.getElementById('polar-year-slider');
    var yearDisplay = document.getElementById('polar-year-display');
    var playBtn = document.getElementById('polar-play-btn');
    var arcticIce = document.getElementById('arctic-ice');
    var arcticExtent = document.getElementById('arctic-extent');
    var antarcticIce = document.getElementById('antarctic-ice');
    var antarcticLoss = document.getElementById('antarctic-loss');
    var antarcticSlr = document.getElementById('antarctic-slr');
    var meltArrows = document.getElementById('melt-arrows');

    if (!slider || !arcticIce) return;

    // Arctic sea ice minimum extent (million km²) — simplified from NSIDC data
    // 1980: ~7.8M km², declining at ~12.4% per decade
    function arcticExtentForYear(year) {
      if (year <= 1980) return 7.8;
      var decades = (year - 1980) / 10;
      var extent = 7.8 * Math.pow(0.876, decades); // 12.4% decline per decade
      return Math.max(3.3, extent); // floor at ~3.3M km² (2012 record low)
    }

    // Antarctic cumulative ice mass loss (Gt) — starts from ~2002 (GRACE era)
    // Pre-2002: minimal measured loss. 2002-2024: ~150 Gt/year average
    function antarcticCumulativeLoss(year) {
      if (year <= 2002) return 0;
      var years = year - 2002;
      // Accelerating: ~100 Gt/yr early, ~150 Gt/yr recent
      return Math.round(years * (100 + (years / 22) * 50));
    }

    function update(year) {
      yearDisplay.textContent = year;

      // Arctic: scale ice circle radius from 130 (1980) to ~55 (2024)
      var extent = arcticExtentForYear(year);
      var maxExtent = 7.8;
      var ratio = extent / maxExtent;
      var radius = 55 + ratio * 75; // 55–130 range
      arcticIce.setAttribute('r', radius);
      arcticExtent.textContent = extent.toFixed(1) + 'M km\u00B2';

      // Antarctic: show ice loss as growing red tint overlay + melt arrows
      var loss = antarcticCumulativeLoss(year);
      var slr = (loss * 0.0028).toFixed(1); // rough conversion: 360 Gt ≈ 1mm SLR
      antarcticLoss.textContent = loss.toLocaleString() + ' Gt';
      antarcticSlr.textContent = slr + ' mm';

      // Show loss as increasingly visible red-tinted overlay on the ice
      var lossIntensity = Math.min(0.25, (loss / 4000) * 0.25);
      antarcticIce.setAttribute('fill', 'rgba(255,110,199,' + lossIntensity + ')');
      antarcticIce.setAttribute('stroke', lossIntensity > 0.02 ? 'rgba(255,110,199,0.5)' : 'none');
      antarcticIce.setAttribute('stroke-width', lossIntensity > 0.02 ? '2' : '0');

      // Show melt arrows after 2002
      if (meltArrows) {
        meltArrows.setAttribute('opacity', year > 2002 ? Math.min(1, (year - 2002) / 10) : 0);
      }
    }

    slider.addEventListener('input', function() {
      update(parseInt(this.value));
    });

    // Play animation
    var animInterval = null;
    playBtn.addEventListener('click', function() {
      if (animInterval) {
        clearInterval(animInterval);
        animInterval = null;
        playBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 3l9 5-9 5V3z" fill="currentColor"/></svg>';
        return;
      }

      slider.value = 1980;
      update(1980);
      playBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="3" y="3" width="4" height="10" fill="currentColor"/><rect x="9" y="3" width="4" height="10" fill="currentColor"/></svg>';

      animInterval = setInterval(function() {
        var val = parseInt(slider.value) + 1;
        if (val > 2024) {
          clearInterval(animInterval);
          animInterval = null;
          playBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 3l9 5-9 5V3z" fill="currentColor"/></svg>';
          return;
        }
        slider.value = val;
        update(val);
      }, 120);
    });

    // Initial state
    update(1980);
  })();
  </script>

  <!-- Lesson 4: Yellow Sea Before/After Slider -->
  <script is:inline>
  (function initBeforeAfter() {
    var container = document.getElementById('yellow-sea-slider');
    var handle = document.getElementById('yellow-sea-handle');
    if (!container || !handle) return;

    var afterSvg = container.querySelector('.before-after-svg--after');
    var dragging = false;

    function setPosition(x) {
      var rect = container.getBoundingClientRect();
      var pct = Math.max(0, Math.min(1, (x - rect.left) / rect.width));
      handle.style.left = (pct * 100) + '%';
      afterSvg.style.clipPath = 'inset(0 0 0 ' + (pct * 100) + '%)';
    }

    container.addEventListener('mousedown', function(e) {
      dragging = true;
      setPosition(e.clientX);
      e.preventDefault();
    });
    document.addEventListener('mousemove', function(e) {
      if (dragging) setPosition(e.clientX);
    });
    document.addEventListener('mouseup', function() { dragging = false; });

    container.addEventListener('touchstart', function(e) {
      dragging = true;
      setPosition(e.touches[0].clientX);
    }, { passive: true });
    document.addEventListener('touchmove', function(e) {
      if (dragging) setPosition(e.touches[0].clientX);
    }, { passive: true });
    document.addEventListener('touchend', function() { dragging = false; });
  })();
  </script>

  <!-- Lesson 4: Sea Turtle Light Toggle -->
  <script is:inline>
  (function initTurtleToggle() {
    var naturalBtn = document.getElementById('turtle-natural-btn');
    var artificialBtn = document.getElementById('turtle-artificial-btn');
    if (!naturalBtn || !artificialBtn) return;

    var windows = document.getElementById('turtle-windows');
    var streetlight = document.getElementById('turtle-streetlight');
    var lightglow = document.getElementById('turtle-lightglow');
    var stars = document.getElementById('turtle-stars');
    var moon = document.getElementById('turtle-moon');
    var moonReflect = document.getElementById('turtle-moonreflect');
    var sky = document.getElementById('turtle-sky');
    var arrowsNatural = document.getElementById('turtle-arrows-natural');
    var arrowsArtificial = document.getElementById('turtle-arrows-artificial');
    var outcomeNatural = document.getElementById('turtle-outcome-natural');
    var outcomeArtificial = document.getElementById('turtle-outcome-artificial');

    function setNatural() {
      naturalBtn.classList.add('turtle-toggle-btn--active');
      artificialBtn.classList.remove('turtle-toggle-btn--active');
      if (windows) windows.setAttribute('opacity', '0');
      if (streetlight) { streetlight.setAttribute('fill', 'rgba(255,200,100,0)'); streetlight.setAttribute('stroke', 'rgba(255,200,100,0)'); }
      if (lightglow) { lightglow.setAttribute('r', '0'); lightglow.setAttribute('opacity', '0'); }
      if (stars) stars.setAttribute('opacity', '1');
      if (moon) moon.setAttribute('opacity', '1');
      if (moonReflect) moonReflect.setAttribute('opacity', '1');
      if (sky) sky.setAttribute('fill', '#0a0e17');
      if (arrowsNatural) arrowsNatural.setAttribute('opacity', '1');
      if (arrowsArtificial) arrowsArtificial.setAttribute('opacity', '0');
      if (outcomeNatural) outcomeNatural.setAttribute('opacity', '1');
      if (outcomeArtificial) outcomeArtificial.setAttribute('opacity', '0');
    }

    function setArtificial() {
      artificialBtn.classList.add('turtle-toggle-btn--active');
      naturalBtn.classList.remove('turtle-toggle-btn--active');
      if (windows) windows.setAttribute('opacity', '1');
      if (streetlight) { streetlight.setAttribute('fill', 'rgba(255,200,100,0.9)'); streetlight.setAttribute('stroke', 'rgba(255,200,100,0.6)'); }
      if (lightglow) { lightglow.setAttribute('r', '120'); lightglow.setAttribute('opacity', '0.15'); }
      if (stars) stars.setAttribute('opacity', '0.15');
      if (moon) moon.setAttribute('opacity', '0.3');
      if (moonReflect) moonReflect.setAttribute('opacity', '0.05');
      if (sky) sky.setAttribute('fill', '#1a1520');
      if (arrowsNatural) arrowsNatural.setAttribute('opacity', '0');
      if (arrowsArtificial) arrowsArtificial.setAttribute('opacity', '1');
      if (outcomeNatural) outcomeNatural.setAttribute('opacity', '0');
      if (outcomeArtificial) outcomeArtificial.setAttribute('opacity', '1');
    }

    naturalBtn.addEventListener('click', setNatural);
    artificialBtn.addEventListener('click', setArtificial);
  })();
  </script>

