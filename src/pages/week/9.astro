      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
    }
    .objectives-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.5em;
      width: 8px;
      height: 8px;
      border: 1.5px solid var(--accent);
      border-radius: 2px;
    }

    /* ── Sidebar Reminders ── */
    .sidebar-reminder {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
      margin-bottom: var(--space-3);
    }
    .sidebar-reminder:last-child { margin-bottom: 0; }
    .sidebar-reminder svg { flex-shrink: 0; margin-top: 2px; color: #fbbf24; }
    .sidebar-reminder strong { color: var(--text-primary); }

    /* ── Sidebar Links ── */
    .sidebar-links {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
      text-decoration: none;
      color: var(--text-secondary);
      font-size: var(--text-sm);
      transition: all var(--transition-fast);
    }
    .sidebar-link:hover { background: var(--surface-2); color: var(--text-primary); }
    .sidebar-link__icon { flex-shrink: 0; }

    .sidebar-text {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin-bottom: var(--space-2);
    }
    .sidebar-text--highlight {
      background: var(--surface-2);
      padding: var(--space-3);
      border-radius: var(--radius-sm);
      border-left: 3px solid var(--accent);
      margin-top: var(--space-3);
    }
  </style>


  <!-- ====================================================================
       Scripts
       ==================================================================== -->
  <script is:inline>

    /* ======================================================================
       IntersectionObserver — Fade-in-up animations
       ====================================================================== */
    (function initObserver() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
    })();

  </script>

</BaseLayout>
