             Lesson 4: Thermoregulation — A Second Homeostatic System
             —————————————————————————————————————————————————————————————— -->
        <section id="lesson-4" class="content-section fade-in-up">
          <nav class="lesson-inline-nav" aria-label="Lesson navigation">
            <span class="lesson-inline-nav__current">Lesson 4 of 4</span>
            <a href="#lesson-3" class="lesson-inline-nav__link lesson-inline-nav__link--prev">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
