  <!-- ====================================================================
       Scripts
       ==================================================================== -->
  <script is:inline>

    /* ======================================================================
       IntersectionObserver — Fade-in-up animations
       ====================================================================== */
    (function initObserver() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
    })();


    /* ======================================================================
       Reveal Buttons — Check Your Understanding
       ====================================================================== */
    (function initRevealBtns() {
      document.querySelectorAll('.reveal-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = document.getElementById(btn.dataset.target);
          if (!target) return;
          const isHidden = target.hidden;
          target.hidden = !isHidden;
          btn.textContent = isHidden ? 'Hide Answer' : 'Reveal Answer';
        });
      });
    })();


    /* ======================================================================
       INTERACTIVE 1 — Blood Glucose After a Meal
       ====================================================================== */
    (function initGlucoseGraph() {
      const clipRect = document.getElementById('gg-clip-rect');
      const markers = document.getElementById('gg-markers');
      const descText = document.getElementById('gg-desc-text');
      const playBtn = document.getElementById('gg-play-btn');
      const stepBtn = document.getElementById('gg-step-btn');
      const resetBtn = document.getElementById('gg-reset-btn');

      if (!clipRect || !markers || !descText) return;

      const TOTAL_WIDTH = 570; // 640 - 70 (start x)
      let currentPhase = -1; // -1 = reset
      let animFrame = null;

      const PHASES = [
        {
          clipWidth: 0,
          desc: 'Fasting state: blood glucose is at the set point (~5 mmol/L). The person has not eaten yet.',
          markers: {}
        },
        {
          clipWidth: 160,
          desc: 'After the meal, glucose is absorbed from the gut into the bloodstream. Blood glucose begins to rise. Beta cells in the islets of Langerhans detect the increase and begin secreting insulin.',
          markers: { 'gg-insulin-line': '0.5', 'gg-insulin-label': '0.8' }
        },
        {
          clipWidth: 280,
          desc: 'Blood glucose peaks at ~8.5 mmol/L around 30 minutes. Insulin is now actively driving glucose into liver (glycogenesis), muscle (GLUT4 translocation), and fat cells.',
          markers: { 'gg-peak-dot': '1', 'gg-peak-label': '1' }
        },
        {
          clipWidth: 450,
          desc: 'Insulin\'s negative feedback mechanisms are working — blood glucose is falling back toward the set point. As glucose drops, less insulin is secreted (feedback regulation).',
          markers: {}
        },
        {
          clipWidth: TOTAL_WIDTH,
          desc: 'Blood glucose returns to ~5 mmol/L (fasting level). Insulin secretion has decreased. If glucose drops below 5 mmol/L, alpha cells release glucagon to release glucose from liver glycogen stores.',
          markers: { 'gg-return-dot': '1', 'gg-return-label': '1' }
        }
      ];

      function resetGraph() {
        currentPhase = -1;
        clipRect.setAttribute('width', '0');
        markers.setAttribute('opacity', '0');
        // Reset all marker elements
        ['gg-peak-dot','gg-peak-label','gg-insulin-line','gg-insulin-label','gg-return-dot','gg-return-label'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.setAttribute('opacity', '0');
        });
        descText.innerHTML = 'Press <strong>Play</strong> to see how blood glucose changes after a meal, and how insulin brings it back to the set point through negative feedback.';
        if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
        playBtn.disabled = false;
        stepBtn.disabled = false;
      }

      function showPhase(phase) {
        if (phase < 0 || phase >= PHASES.length) return;
        currentPhase = phase;
        var p = PHASES[phase];

        // Animate clip width
        clipRect.setAttribute('width', String(p.clipWidth));

        // Show markers
        markers.setAttribute('opacity', '1');
        // Show phase-specific markers
        if (p.markers) {
          Object.keys(p.markers).forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.setAttribute('opacity', p.markers[id]);
          });
        }

        descText.innerHTML = p.desc;

        if (phase >= PHASES.length - 1) {
          playBtn.disabled = true;
          stepBtn.disabled = true;
        }
      }

      // Play animation (auto-advance through phases)
      function playAnimation() {
        resetGraph();
        var phase = 0;
        function nextPhase() {
          showPhase(phase);
          phase++;
          if (phase < PHASES.length) {
            animFrame = setTimeout(nextPhase, 2000);
          }
        }
        nextPhase();
      }

      // Step through phases manually
      stepBtn.addEventListener('click', function() {
        currentPhase++;
        if (currentPhase >= PHASES.length) return;
        showPhase(currentPhase);
      });

      playBtn.addEventListener('click', playAnimation);
      resetBtn.addEventListener('click', resetGraph);

      resetGraph();
    })();


    /* ======================================================================
       INTERACTIVE 2 — Insulin Signalling Step-Through
       ====================================================================== */
    (function initSignalAnim() {
      var currentStep = -1;
      var descText = document.getElementById('sig-desc-text');
      var stepLabel = document.getElementById('sig-step-label');
      var prevBtn = document.getElementById('sig-prev-btn');
      var nextBtn = document.getElementById('sig-next-btn');
      var resetBtn = document.getElementById('sig-reset-btn');

      if (!descText || !nextBtn) return;

      var STEPS = [
        {
          label: 'Step 1: Insulin arrives',
          desc: 'Insulin molecules (released from beta cells) travel through the bloodstream and reach the surface of a muscle or fat cell. The insulin receptor spans the plasma membrane.',
          show: ['sig-insulin'],
          highlight: 'sig-insulin'
        },
        {
          label: 'Step 2: Receptor binding & activation',
          desc: 'Insulin binds to the extracellular domain of the insulin receptor. This causes an allosteric shape change in the intracellular domain, activating its enzymatic (kinase) activity. The hormone signal is transduced across the membrane without insulin entering the cell.',
          show: ['sig-insulin'],
          highlight: 'sig-receptor'
        },
        {
          label: 'Step 3: Phosphorylation cascade',
          desc: 'The activated receptor phosphorylates intracellular proteins (adds phosphate groups), triggering a chain reaction — a signal transduction cascade. Each step amplifies the signal.',
          show: ['sig-insulin', 'sig-cascade'],
          highlight: 'sig-cascade'
        },
        {
          label: 'Step 4: GLUT4 vesicles move to membrane',
          desc: 'The cascade causes vesicles containing GLUT4 glucose transporters to move to and fuse with the plasma membrane. GLUT4 is now embedded in the cell surface, creating channels for glucose.',
          show: ['sig-insulin', 'sig-cascade', 'sig-glut4-membrane'],
          highlight: 'sig-glut4-membrane'
        },
        {
          label: 'Step 5: Glucose enters the cell',
          desc: 'With GLUT4 in the membrane, glucose flows into the cell down its concentration gradient (facilitated diffusion — no energy required). Blood glucose falls. The insulin receptor will soon be internalised and the signal shut off (~1 minute).',
          show: ['sig-insulin', 'sig-cascade', 'sig-glut4-membrane', 'sig-glucose-entering'],
          highlight: 'sig-glucose-entering'
        }
      ];

      var ALL_IDS = ['sig-insulin', 'sig-cascade', 'sig-glut4-membrane', 'sig-glucose-entering'];

      function reset() {
        currentStep = -1;
        ALL_IDS.forEach(function(id) {
          var el = document.getElementById(id);
          if (el) { el.setAttribute('opacity', id === 'sig-insulin' ? '1' : '0'); el.removeAttribute('filter'); }
        });
        // Reset vesicle to original position
        var vesicle = document.getElementById('sig-vesicle');
        if (vesicle) vesicle.setAttribute('opacity', '1');

        var glucose = document.getElementById('sig-glucose');
        if (glucose) glucose.setAttribute('opacity', '0.3');

        var receptor = document.getElementById('sig-receptor');
        if (receptor) { receptor.querySelector('rect').setAttribute('stroke', 'var(--border-subtle)'); }

        if (stepLabel) stepLabel.textContent = 'Click "Next Step" to begin';
        descText.textContent = 'This animation shows how insulin triggers glucose uptake in muscle and fat cells through signal transduction and GLUT4 vesicle translocation.';

        document.querySelectorAll('.sig-step-dot').forEach(function(dot) {
          dot.classList.remove('is-active', 'is-done');
        });

        if (prevBtn) prevBtn.disabled = true;
        nextBtn.disabled = false;
        nextBtn.textContent = 'Next Step';
      }

      function renderStep(step) {
        var data = STEPS[step];
        if (!data) return;

        // Show/hide elements
        ALL_IDS.forEach(function(id) {
          var el = document.getElementById(id);
          if (!el) return;
          var shouldShow = data.show.indexOf(id) !== -1;
          el.setAttribute('opacity', shouldShow ? '1' : '0');
          el.removeAttribute('filter');
        });

        // Highlight active element
        if (data.highlight) {
          var hl = document.getElementById(data.highlight);
          if (hl) hl.setAttribute('filter', 'url(#sig-glow)');
        }

        // Hide vesicle when GLUT4 is in membrane
        var vesicle = document.getElementById('sig-vesicle');
        if (vesicle) vesicle.setAttribute('opacity', step >= 3 ? '0' : '1');

        // Show glucose molecules brighter at step 4+
        var glucose = document.getElementById('sig-glucose');
        if (glucose) glucose.setAttribute('opacity', step >= 4 ? '0.8' : '0.3');

        // Receptor highlight
        var receptor = document.getElementById('sig-receptor');
        if (receptor) {
          var rect = receptor.querySelector('rect');
          if (rect) rect.setAttribute('stroke', step >= 1 ? 'var(--fluoro-cyan)' : 'var(--border-subtle)');
        }

        // Update text
        if (stepLabel) stepLabel.textContent = data.label;
        descText.textContent = data.desc;

        // Dots
        document.querySelectorAll('.sig-step-dot').forEach(function(dot, i) {
          dot.classList.toggle('is-active', i === step);
          dot.classList.toggle('is-done', i < step);
        });

        // Buttons
        if (prevBtn) prevBtn.disabled = step === 0;
        nextBtn.disabled = false;
        nextBtn.textContent = step === STEPS.length - 1 ? 'Restart' : 'Next Step';
      }

      nextBtn.addEventListener('click', function() {
        if (currentStep >= STEPS.length - 1) { reset(); return; }
        currentStep++;
        renderStep(currentStep);
      });

      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          if (currentStep <= 0) return;
          currentStep--;
          renderStep(currentStep);
        });
      }

      resetBtn.addEventListener('click', reset);
      reset();
    })();


    /* ======================================================================
       INTERACTIVE 3 — OGTT Comparison
       ====================================================================== */
    (function initOGTT() {
      var curves = {
        normal:    { id: 'ogtt-normal',    active: true,  desc: '<strong>Normal:</strong> Blood glucose peaks at ~8 mmol/L around 30 minutes, then returns to ~5 mmol/L within 2 hours as insulin drives uptake into liver, muscle, and fat.' },
        resistant: { id: 'ogtt-resistant',  active: false, desc: '<strong>Insulin Resistant:</strong> Fasting glucose is slightly elevated (~6 mmol/L). The peak is higher and it takes longer to return to baseline — insulin is present but receptors respond poorly.' },
        type2:     { id: 'ogtt-type2',      active: false, desc: '<strong>Type 2 Diabetic:</strong> Fasting glucose elevated (~7.5 mmol/L). Peak reaches ~10 mmol/L and glucose remains elevated even at 3 hours. Some insulin function remains but is severely impaired.' },
        type1:     { id: 'ogtt-type1',      active: false, desc: '<strong>Type 1 Diabetic:</strong> Fasting glucose very high (~12 mmol/L) because there is no insulin. After the glucose load, levels rise even further and barely fall — no insulin means no negative feedback mechanism.' }
      };

      var descEl = document.getElementById('ogtt-desc-text');

      function updateCurves() {
        var activeDescs = [];
        Object.keys(curves).forEach(function(key) {
          var c = curves[key];
          var el = document.getElementById(c.id);
          if (el) el.setAttribute('opacity', c.active ? '1' : '0');
          if (c.active) activeDescs.push(c.desc);
        });
        if (descEl) descEl.innerHTML = activeDescs.join('<br/><br/>') || 'Toggle a condition to see its OGTT curve.';
      }

      document.querySelectorAll('.ogtt-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var curve = btn.dataset.curve;
          if (!curve || !curves[curve]) return;
          curves[curve].active = !curves[curve].active;
          btn.classList.toggle('ogtt-toggle--active', curves[curve].active);
          updateCurves();
        });
      });

      updateCurves();
    })();

  </script>

</BaseLayout>
