  <!-- ====================================================================
       Scripts
       ==================================================================== -->
  <script>
    /* ======================================================================
       Fade-in observer
       ====================================================================== */
    (function () {
      const obs = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('.fade-in-up').forEach((el) => obs.observe(el));
    })();


    /* ======================================================================
       Reveal buttons
       ====================================================================== */
    document.querySelectorAll('.reveal-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target;
        if (!targetId) return;
        const content = document.getElementById(targetId);
        if (!content) return;
        const isHidden = content.hidden;
        content.hidden = !isHidden;
        const label = btn.querySelector('.reveal-btn__text');
        if (label) label.textContent = isHidden ? 'Hide Answers' : 'Show Model Answers';
        const arrow = btn.querySelector('svg');
        if (arrow) arrow.style.transform = isHidden ? 'rotate(180deg)' : '';
      });
    });


    /* ======================================================================
       INTERACTIVE 1 — Negative Feedback Loop Animation
       ====================================================================== */
    (function initFeedbackAnim() {

      const SYSTEMS: Record<string, { steps: { label: string; example: string }[] }> = {
        temperature: {
          steps: [
            {
              label: 'Stimulus: Core body temperature rises above 37°C (e.g. during exercise or in a hot environment).',
              example: 'Example: After a run, core temp climbs to 38.5°C — above the normal range.'
            },
            {
              label: 'Receptor: Thermoreceptors in the hypothalamus detect the rise in blood temperature. Peripheral skin thermoreceptors also send signals.',
              example: 'Example: The hypothalamic thermostat registers a deviation from the 37°C set point.'
            },
            {
              label: 'Control Centre: The hypothalamus compares the signal to the set point (37°C) and activates cooling pathways via the nervous system and hormones.',
              example: 'Example: The hypothalamus sends nerve signals to sweat glands and blood vessels in the skin.'
            },
            {
              label: 'Effector: Sweat glands secrete sweat; arterioles in the skin dilate (vasodilation); muscles reduce heat production.',
              example: 'Example: Sweat glands across the body surface produce watery secretion; skin arterioles widen to bring more blood to the surface.'
            },
            {
              label: 'Response: Evaporation of sweat and increased heat loss via radiation from dilated skin vessels cools the blood. Temperature returns to ~37°C — negative feedback complete.',
              example: 'Example: As core temp falls back to 37°C, the hypothalamus reduces its cooling signals — the response stops (negative feedback loop closed).'
            }
          ]
        },
        glucose: {
          steps: [
            {
              label: 'Stimulus: Blood glucose concentration rises above ~6 mmol/L after a meal.',
              example: 'Example: After eating a bowl of rice, blood glucose climbs to 8 mmol/L — above the normal range.'
            },
            {
              label: 'Receptor: Beta cells in the islets of Langerhans (pancreas) detect elevated blood glucose directly as blood flows through the pancreas.',
              example: 'Example: Beta cells have glucose transporters (GLUT2) that allow glucose to enter in proportion to blood glucose concentration — this triggers insulin secretion.'
            },
            {
              label: 'Control Centre: Beta cells also act as the integration centre — they secrete insulin into the bloodstream in response to the elevated glucose signal.',
              example: 'Example: Insulin is released into the portal circulation and reaches the liver and muscle cells within minutes.'
            },
            {
              label: 'Effector: Liver cells (hepatocytes) and muscle cells respond to insulin — they increase glucose uptake and convert glucose to glycogen (glycogenesis). Adipose tissue increases glucose uptake and lipid synthesis.',
              example: 'Example: Liver converts glucose → glycogen (stored); muscle uses glucose for contraction or converts it to glycogen.'
            },
            {
              label: 'Response: Blood glucose falls back toward ~5 mmol/L. As glucose drops, beta cells reduce insulin secretion — the feedback loop is closed. (If glucose falls too far, alpha cells secrete glucagon, which raises it back — the opposing arm of regulation.)',
              example: 'Example: 1–2 hours after the meal, blood glucose has returned to the fasting set point. Insulin levels fall, reducing further glucose uptake.'
            }
          ]
        },
        osmoregulation: {
          steps: [
            {
              label: 'Stimulus: Plasma osmolarity rises above ~290 mOsm/kg — e.g. due to dehydration or eating salty food.',
              example: 'Example: After a salty meal without drinking water, plasma osmolarity rises to 296 mOsm/kg.'
            },
            {
              label: 'Receptor: Osmoreceptors in the hypothalamus (supraoptic and paraventricular nuclei) detect the increased osmolarity as water moves out of these specialised neurons by osmosis.',
              example: 'Example: Osmoreceptor neurons shrink slightly as their water moves into the hypertonic blood — this triggers a nerve impulse.'
            },
            {
              label: 'Control Centre: The hypothalamus signals the posterior pituitary gland to release ADH (antidiuretic hormone, also called vasopressin) into the bloodstream.',
              example: 'Example: ADH is synthesised in the hypothalamus but stored and released from the posterior pituitary.'
            },
            {
              label: 'Effector: Collecting ducts and distal tubules of the kidney nephrons respond to ADH — aquaporin-2 (water channel) proteins are inserted into the tubule membrane, dramatically increasing water permeability.',
              example: 'Example: With high ADH, up to 99% of the filtered water is reabsorbed, producing a small volume of highly concentrated urine.'
            },
            {
              label: 'Response: More water is reabsorbed into the blood, diluting the plasma and returning osmolarity toward 290 mOsm/kg. As osmolarity falls, ADH secretion decreases — negative feedback complete.',
              example: 'Example: Urine becomes dark yellow and low-volume. Blood osmolarity returns to ~290 mOsm/kg, osmoreceptors stop firing, ADH release decreases.'
            }
          ]
        }
      };

      let currentSystem = 'temperature';
      let currentStep = -1; // -1 = not started

      const STEP_BOXES = ['fb-box-0', 'fb-box-1', 'fb-box-2', 'fb-box-3', 'fb-box-4'];
      const STEP_ARROWS = ['fb-arrow-01', 'fb-arrow-12', 'fb-arrow-23', 'fb-arrow-34'];
      const STEP_COLORS = [
        'var(--fluoro-pink)',
        'var(--fluoro-cyan)',
        'var(--accent)',
        'var(--green-vivid)',
        'var(--purple-light, #c084fc)'
      ];

      function getEl(id: string): SVGElement | null {
        return document.getElementById(id) as SVGElement | null;
      }

      function reset() {
        currentStep = -1;
        STEP_BOXES.forEach((id) => {
          const el = getEl(id);
          if (el) {
            el.setAttribute('stroke', 'var(--border-subtle)');
            el.setAttribute('fill', 'var(--surface-2)');
            el.setAttribute('stroke-width', '1.5');
          }
        });
        STEP_ARROWS.forEach((id) => {
          const el = getEl(id);
          if (el) el.setAttribute('opacity', '0.3');
        });
        const normalLabel = getEl('fb-normal-label');
        const normalLine  = getEl('fb-normal-line');
        if (normalLabel) normalLabel.setAttribute('opacity', '0');
        if (normalLine)  normalLine.setAttribute('opacity', '0');

        const stepLabel = getEl('fb-step-label');
        if (stepLabel) stepLabel.textContent = 'Click "Next Step" to begin';

        const desc = document.getElementById('fb-desc-text');
        const ex   = document.getElementById('fb-example-text');
        if (desc) desc.textContent = 'The negative feedback loop has five key components. Step through each one to see how they connect in a real homeostatic system.';
        if (ex)   ex.textContent = '';

        document.querySelectorAll('.fb-step-dot').forEach((dot) => {
          dot.classList.remove('is-active', 'is-done');
        });

        const prevBtn = document.getElementById('fb-prev-btn') as HTMLButtonElement | null;
        const nextBtn = document.getElementById('fb-next-btn') as HTMLButtonElement | null;
        if (prevBtn) prevBtn.disabled = true;
        if (nextBtn) { nextBtn.disabled = false; nextBtn.textContent = 'Next Step'; }
      }

      function renderStep(step: number) {
        const system = SYSTEMS[currentSystem];
        if (!system) return;

        // Highlight boxes 0..step, grey rest
        STEP_BOXES.forEach((id, i) => {
          const el = getEl(id);
          if (!el) return;
          if (i <= step) {
            el.setAttribute('stroke', STEP_COLORS[i]);
            el.setAttribute('stroke-width', i === step ? '2.5' : '1.5');
            el.setAttribute('filter', i === step ? 'url(#glow-filter)' : '');
          } else {
            el.setAttribute('stroke', 'var(--border-subtle)');
            el.setAttribute('stroke-width', '1.5');
            el.setAttribute('filter', '');
          }
        });

        // Arrows 0..step-1
        STEP_ARROWS.forEach((id, i) => {
          const el = getEl(id);
          if (!el) return;
          el.setAttribute('opacity', i < step ? '0.8' : '0.3');
          if (i < step) {
            el.setAttribute('stroke', STEP_COLORS[i]);
          }
        });

        // Show "return to normal" if on final step
        const normalLabel = getEl('fb-normal-label');
        const normalLine  = getEl('fb-normal-line');
        if (step === 4) {
          if (normalLabel) normalLabel.setAttribute('opacity', '1');
          if (normalLine)  normalLine.setAttribute('opacity', '0.5');
        } else {
          if (normalLabel) normalLabel.setAttribute('opacity', '0');
          if (normalLine)  normalLine.setAttribute('opacity', '0');
        }

        // Step label
        const names = ['Stimulus', 'Receptor', 'Control Centre', 'Effector', 'Response'];
        const stepLabel = getEl('fb-step-label');
        if (stepLabel) stepLabel.textContent = `Step ${step + 1} of 5: ${names[step]}`;

        // Description
        const data = system.steps[step];
        const desc = document.getElementById('fb-desc-text');
        const ex   = document.getElementById('fb-example-text');
        if (desc && data) desc.textContent = data.label;
        if (ex  && data) ex.textContent   = data.example;

        // Dots
        document.querySelectorAll('.fb-step-dot').forEach((dot, i) => {
          dot.classList.toggle('is-active', i === step);
          dot.classList.toggle('is-done', i < step);
        });

        // Buttons
        const prevBtn = document.getElementById('fb-prev-btn') as HTMLButtonElement | null;
        const nextBtn = document.getElementById('fb-next-btn') as HTMLButtonElement | null;
        if (prevBtn) prevBtn.disabled = step === 0;
        if (nextBtn) {
          nextBtn.disabled = false;
          nextBtn.innerHTML = step === 4
            ? 'Restart <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
            : 'Next Step <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        }
      }

      document.getElementById('fb-next-btn')?.addEventListener('click', () => {
        if (currentStep === 4) { reset(); return; }
        currentStep++;
        renderStep(currentStep);
      });

      document.getElementById('fb-prev-btn')?.addEventListener('click', () => {
        if (currentStep <= 0) return;
        currentStep--;
        renderStep(currentStep);
      });

      document.getElementById('fb-reset-btn')?.addEventListener('click', reset);

      document.querySelectorAll('.fb-system-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const sys = (btn as HTMLElement).dataset.system;
          if (!sys) return;
          currentSystem = sys;
          document.querySelectorAll('.fb-system-btn').forEach((b) => b.classList.remove('fb-system-btn--active'));
          btn.classList.add('fb-system-btn--active');
          reset();
        });
      });

      reset();
    })();


    /* ======================================================================
       INTERACTIVE 2 — Set Point Visualiser
       ====================================================================== */
    (function initSetPointVis() {

      const slider = document.getElementById('sp-slider') as HTMLInputElement | null;
      if (!slider) return;

      const SET_POINT = 37.0;
      const TEMP_MIN  = 34.0;   // gauge bottom
      const TEMP_MAX  = 41.0;   // gauge top
      const CORE_MIN  = 34.5;   // below this = hypothermia danger
      const CORE_MAX  = 40.5;   // above this = hyperthermia danger

      function calcCoreTemp(extTemp: number): number {
        // Model: body maintains 37°C through a range of ext temps
        // Below -5°C: body struggles; above 45°C: body struggles
        if (extTemp < -15) {
          return Math.max(CORE_MIN - 0.2, 37 - (Math.abs(extTemp + 15) * 0.18));
        } else if (extTemp < 5) {
          return 37 - (5 - extTemp) * 0.04;  // slight dip, well-controlled
        } else if (extTemp <= 35) {
          return 37.0 + (extTemp - 20) * 0.005; // essentially stable
        } else if (extTemp <= 50) {
          return 37 + (extTemp - 35) * 0.12;    // warming
        } else {
          return 37 + (50 - 35) * 0.12 + (extTemp - 50) * 0.25; // overwhelmed
        }
      }

      function getGaugeFill(coreTemp: number): number {
        // Returns 0..100 for gauge fill
        return Math.min(100, Math.max(0,
          ((coreTemp - TEMP_MIN) / (TEMP_MAX - TEMP_MIN)) * 100
        ));
      }

      function getGaugeColor(coreTemp: number): string {
        if (coreTemp < 35.5) return 'var(--fluoro-cyan)';
        if (coreTemp > 39.5) return 'var(--fluoro-pink)';
        if (coreTemp < 36.1 || coreTemp > 37.5) return '#fbbf24';
        return 'var(--green-vivid)';
      }

      function update() {
        const extTemp = Number(slider!.value);
        const coreTemp = calcCoreTemp(extTemp);
        const coreTempRounded = Math.round(coreTemp * 10) / 10;

        // Update display values
        const extTempEl = document.getElementById('sp-ext-temp');
        const readoutEl = document.getElementById('sp-core-temp-readout');
        const statusEl  = document.getElementById('sp-status');
        const gaugeFill = document.getElementById('sp-gauge-fill');
        const warningEl = document.getElementById('sp-warning') as HTMLElement | null;
        const warningTxt = document.getElementById('sp-warning-text');
        const explanEl  = document.getElementById('sp-explanation');

        if (extTempEl) extTempEl.textContent = `${extTemp}°C`;
        if (readoutEl) {
          readoutEl.textContent = `${coreTempRounded.toFixed(1)}°C`;
          readoutEl.style.color = getGaugeColor(coreTemp);
        }

        // Gauge fill
        if (gaugeFill) {
          const pct = getGaugeFill(coreTemp);
          gaugeFill.style.height = `${pct}%`;
          gaugeFill.style.background = getGaugeColor(coreTemp);
        }

        // Set point marker position
        const setPointMarker = document.querySelector('.gauge-setpoint') as HTMLElement | null;
        if (setPointMarker) {
          const pct = ((SET_POINT - TEMP_MIN) / (TEMP_MAX - TEMP_MIN)) * 100;
          setPointMarker.style.bottom = `${pct}%`;
        }

        // Status
        if (statusEl) {
          statusEl.className = 'gauge-status';
          if (coreTemp < 35.0) {
            statusEl.textContent = 'Danger: Hypothermia';
            statusEl.classList.add('gauge-status--danger');
          } else if (coreTemp < 36.1) {
            statusEl.textContent = 'Warning: Below range';
            statusEl.classList.add('gauge-status--warn');
          } else if (coreTemp > 40.0) {
            statusEl.textContent = 'Danger: Hyperthermia';
            statusEl.classList.add('gauge-status--danger');
          } else if (coreTemp > 37.5) {
            statusEl.textContent = 'Warning: Above range';
            statusEl.classList.add('gauge-status--warn');
          } else {
            statusEl.textContent = 'Normal';
            statusEl.classList.add('gauge-status--normal');
          }
        }

        // Active responses
        const isHot  = extTemp > 25;
        const isCold = extTemp < 15;
        const isVeryHot  = extTemp > 45;
        const isVeryCold = extTemp < -10;

        const respSweat = document.getElementById('resp-sweat');
        const respVaso  = document.getElementById('resp-vasodilation');
        const respShiv  = document.getElementById('resp-shivering');
        const respVC    = document.getElementById('resp-vasoconstriction');
        const respPilo  = document.getElementById('resp-piloerection');

        [respSweat, respVaso, respShiv, respVC, respPilo].forEach((el) => {
          if (!el) return;
          el.className = 'response-item response-item--inactive';
        });

        if (isHot) {
          respSweat?.classList.replace('response-item--inactive', 'response-item--active');
          respVaso?.classList.replace('response-item--inactive', 'response-item--active');
        }
        if (isCold) {
          respShiv?.classList.replace('response-item--inactive', 'response-item--active-cold');
          respVC?.classList.replace('response-item--inactive', 'response-item--active-cold');
          respPilo?.classList.replace('response-item--inactive', 'response-item--active-cold');
        }

        // Warning
        if (warningEl && warningTxt) {
          if (isVeryHot) {
            warningEl.hidden = false;
            warningTxt.textContent = 'Homeostatic mechanisms overwhelmed. At external temperatures above 45°C, the body cannot lose heat fast enough. Core temperature rises dangerously — heat stroke can occur above 40°C core temp.';
          } else if (isVeryCold) {
            warningEl.hidden = false;
            warningTxt.textContent = 'Homeostatic mechanisms overwhelmed. In severe cold, heat production cannot keep pace with heat loss. Core temperature falls — hypothermia begins below 35°C core temp and becomes life-threatening below 32°C.';
          } else {
            warningEl.hidden = true;
          }
        }

        // Explanation
        if (explanEl) {
          if (extTemp <= -10) {
            explanEl.textContent = `Very cold environment (${extTemp}°C). The body is working hard to prevent heat loss: vasoconstriction reduces blood flow to extremities, shivering generates heat from muscle contractions, and piloerection traps an insulating air layer. At extreme cold, these mechanisms may be overwhelmed.`;
          } else if (extTemp < 15) {
            explanEl.textContent = `Cool environment (${extTemp}°C). Negative feedback is active — the body detects core temperature dropping slightly below 37°C. The hypothalamus triggers vasoconstriction and shivering to conserve and generate heat, returning temperature toward the set point.`;
          } else if (extTemp <= 25) {
            explanEl.textContent = `Comfortable range (${extTemp}°C). The body is close to thermal neutrality — minimal physiological effort required to maintain 37°C. Very slight vasodilation may occur to fine-tune heat exchange.`;
          } else if (extTemp <= 40) {
            explanEl.textContent = `Warm environment (${extTemp}°C). The body detects rising core temperature and activates cooling responses: sweating produces water for evaporative cooling, and vasodilation brings warm blood to the skin surface to radiate heat. These negative feedback responses return temperature to ~37°C.`;
          } else {
            explanEl.textContent = `Extreme heat (${extTemp}°C). Homeostatic mechanisms are under severe strain. Sweating can remove large volumes of fluid, risking dehydration. Above ~45°C external, the body struggles to maintain its set point — core temperature begins to rise despite maximum cooling effort.`;
          }
        }
      }

      slider.addEventListener('input', update);
      update(); // Initial render
    })();


    /* ======================================================================
       INTERACTIVE 3 — Matching Activity
       ====================================================================== */
    (function initMatching() {

      let selectedLeft: HTMLElement | null  = null;
      let selectedRight: HTMLElement | null = null;
      let matchCount = 0;

      function resetSelection() {
        selectedLeft  = null;
        selectedRight = null;
        document.querySelectorAll('.match-card.is-selected').forEach((el) => el.classList.remove('is-selected'));
      }

      function tryMatch() {
        if (!selectedLeft || !selectedRight) return;
        const leftId  = selectedLeft.dataset.matchId;
        const rightId = selectedRight.dataset.matchId;

        if (leftId === rightId) {
          // Correct match
          selectedLeft.classList.remove('is-selected');
          selectedRight.classList.remove('is-selected');
          selectedLeft.classList.add('is-matched');
          selectedRight.classList.add('is-matched');
          matchCount++;
          const countEl = document.getElementById('match-count');
          if (countEl) countEl.textContent = String(matchCount);
          if (matchCount === 4) {
            const complete = document.getElementById('matching-complete');
            if (complete) complete.hidden = false;
          }
          selectedLeft  = null;
          selectedRight = null;
        } else {
          // Wrong match — flash red then reset
          selectedLeft.classList.add('is-wrong');
          selectedRight.classList.add('is-wrong');
          const lCopy  = selectedLeft;
          const rCopy  = selectedRight;
          setTimeout(() => {
            lCopy.classList.remove('is-wrong', 'is-selected');
            rCopy.classList.remove('is-wrong', 'is-selected');
          }, 600);
          selectedLeft  = null;
          selectedRight = null;
        }
      }

      document.querySelectorAll('.match-card').forEach((card) => {
        card.addEventListener('click', () => {
          const el   = card as HTMLElement;
          const side = el.dataset.side;
          if (el.classList.contains('is-matched')) return;

          if (side === 'left') {
            document.querySelectorAll('.match-card[data-side="left"]').forEach((c) => c.classList.remove('is-selected'));
            selectedLeft = el;
            el.classList.add('is-selected');
          } else {
            document.querySelectorAll('.match-card[data-side="right"]').forEach((c) => c.classList.remove('is-selected'));
            selectedRight = el;
            el.classList.add('is-selected');
          }

          if (selectedLeft && selectedRight) tryMatch();
        });
      });

      document.getElementById('matching-reset-btn')?.addEventListener('click', () => {
        matchCount = 0;
        selectedLeft  = null;
        selectedRight = null;
        document.querySelectorAll('.match-card').forEach((card) => {
          card.classList.remove('is-selected', 'is-matched', 'is-wrong');
        });
        const countEl   = document.getElementById('match-count');
        const completeEl = document.getElementById('matching-complete');
        if (countEl)    countEl.textContent = '0';
        if (completeEl) completeEl.hidden = true;
      });
    })();


    /* ======================================================================
       Word count for assessment textarea
       ====================================================================== */
    (function initWordCount() {
      const ta = document.getElementById('assessment-answer') as HTMLTextAreaElement | null;
      const wc = document.getElementById('assessment-word-count');
      if (!ta || !wc) return;
      ta.addEventListener('input', () => {
        const n = ta.value.trim().split(/\s+/).filter(Boolean).length;
        wc.textContent = `${n} word${n !== 1 ? 's' : ''}`;
      });
    })();


    /* ======================================================================
       AI Feedback for Assessment Practice Task
       ====================================================================== */
    (function initAIFeedback() {
      const AI_URL  = 'https://psychology-ai-marker.deornorth.workers.dev';
      const RL_KEY  = 'l3_bio_homeostasis_ai_rate';
      const LIMIT   = 10;

      const submitBtn  = document.getElementById('assessment-submit-btn');
      const answerEl   = document.getElementById('assessment-answer') as HTMLTextAreaElement | null;
      const feedbackEl = document.getElementById('ai-feedback');
      const loadingEl  = document.getElementById('ai-loading');
      const errorEl    = document.getElementById('ai-error');
      const errorTxtEl = document.getElementById('ai-error-text');

      function todayKey() { return new Date().toISOString().slice(0, 10); }
      function getCount(): number {
        try { return (JSON.parse(localStorage.getItem(RL_KEY) || '{}'))[todayKey()] || 0; }
        catch { return 0; }
      }
      function bump() {
        const k = todayKey();
        let d: Record<string, number> = {};
        try { d = JSON.parse(localStorage.getItem(RL_KEY) || '{}'); } catch { /* noop */ }
        d[k] = (d[k] || 0) + 1;
        localStorage.setItem(RL_KEY, JSON.stringify(d));
      }

      function showError(msg: string) {
        if (errorEl)    errorEl.hidden    = false;
        if (errorTxtEl) errorTxtEl.textContent = msg;
        if (feedbackEl) feedbackEl.hidden = true;
        if (loadingEl)  loadingEl.hidden  = true;
      }

      function populateList(id: string, items: string[] | undefined) {
        const ul = document.getElementById(id);
        if (!ul) return;
        ul.innerHTML = '';
        (items || []).forEach((item) => {
          const li = document.createElement('li');
          li.textContent = item;
          ul.appendChild(li);
        });
      }

      function displayFeedback(data: any) {
        if (!feedbackEl) return;
        feedbackEl.hidden = false;
        const gradeEl = document.getElementById('ai-grade');
        const gradeMap: Record<string, string> = {
          NA: 'Not Achieved', A: 'Achieved', M: 'Merit', E: 'Excellence'
        };
        if (gradeEl) {
          gradeEl.textContent = gradeMap[data.grade] || data.grade;
          gradeEl.className   = 'ai-grade ai-grade--' + (data.grade || 'na').toLowerCase();
        }
        const sumEl = document.getElementById('ai-summary');
        if (sumEl) sumEl.textContent = data.summary || '';
        populateList('ai-strengths',    data.strengths);
        populateList('ai-improvements', data.improvements);
        populateList('ai-missing',      data.missingPoints);

        const sStr  = document.getElementById('ai-strengths-section');
        const sImp  = document.getElementById('ai-improvements-section');
        const sMiss = document.getElementById('ai-missing-section');
        if (sStr)  sStr.hidden  = !data.strengths?.length;
        if (sImp)  sImp.hidden  = !data.improvements?.length;
        if (sMiss) sMiss.hidden = !data.missingPoints?.length;

        const tipEl = document.getElementById('ai-tip');
        if (tipEl) { tipEl.textContent = data.tip || ''; tipEl.hidden = !data.tip; }
      }

      submitBtn?.addEventListener('click', async () => {
        if (!answerEl) return;
        const answer = answerEl.value.trim();
        if (answer.length < 30) {
          showError('Please write a more complete answer before submitting (aim for at least 80 words).');
          return;
        }
        if (getCount() >= LIMIT) {
          showError(`You have used your ${LIMIT} daily AI feedback submissions. Try again tomorrow.`);
          return;
        }

        if (loadingEl) loadingEl.hidden = false;
        if (feedbackEl) feedbackEl.hidden = true;
        if (errorEl)   errorEl.hidden   = true;

        bump();

        const PROMPT = `You are Dr Eliot's AI assessment marker for Year 13 (Level 3) Biology — AS 91604 (Internal assessment).

The student was asked to explain how Priya's body maintains homeostasis during and after a 5 km run on a warm day, covering at least two of: thermoregulation, blood glucose regulation, or blood pH/CO₂ regulation. For each system, they should identify receptor, control centre, effector(s), and response, explain negative feedback, and link the regulated variable to a biological consequence of failure.

Assess using NCEA Achievement Standard criteria:
- Not Achieved: Missing core components or no explanation of negative feedback
- Achieved: Describes at least two complete negative feedback loops with correct components
- Merit: Explains how negative feedback opposes the deviation in both systems; links to set point
- Excellence: Integrates biological consequences; links mechanism to cell/enzyme function; shows depth

Student answer: "${answer}"

Return a JSON object with:
{
  "grade": "NA" | "A" | "M" | "E",
  "summary": "2–3 sentence overall assessment",
  "strengths": ["strength 1", "strength 2"],
  "improvements": ["improvement 1", "improvement 2"],
  "missingPoints": ["key point not covered..."],
  "tip": "one specific writing tip for this student"
}`;

        try {
          const res = await fetch(AI_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: PROMPT })
          });

          if (!res.ok) throw new Error(`Server responded with ${res.status}`);

          const text = await res.text();
          let data: any;
          try {
            const jsonMatch = text.match(/\{[\s\S]*\}/);
            data = jsonMatch ? JSON.parse(jsonMatch[0]) : JSON.parse(text);
          } catch {
            throw new Error('Could not parse AI response. Please try again.');
          }

          if (loadingEl) loadingEl.hidden = true;
          displayFeedback(data);

        } catch (err: any) {
          showError(err?.message || 'Something went wrong. Please try again in a moment.');
        }
      });
    })();

  </script>

</BaseLayout>
