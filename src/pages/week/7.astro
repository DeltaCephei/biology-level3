    }
    .term-card h4 { margin-top: 0; margin-bottom: var(--space-2); }
    .term-card p { font-size: var(--text-sm) !important; margin-bottom: var(--space-3) !important; }
    .term-example {
      background: var(--surface-0);
      border-radius: var(--radius-sm);
      padding: var(--space-3);
      font-size: var(--text-xs);
      color: var(--text-muted);
      line-height: var(--leading-relaxed);
    }
    .term-example__label {
      display: block;
      font-weight: var(--weight-semibold);
      font-family: var(--font-mono);
      color: var(--accent);
      margin-bottom: var(--space-1);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .term-card--stimulus    { border-left: 3px solid var(--fluoro-pink); }
    .term-card--receptor    { border-left: 3px solid var(--fluoro-cyan); }
    .term-card--control     { border-left: 3px solid var(--accent); }
    .term-card--effector    { border-left: 3px solid var(--green-vivid); }
    .term-card--response    { border-left: 3px solid var(--purple-light, #c084fc); }

    /* ── Connection Box ── */
    .connection-box {
      background: var(--surface-2);
      border: 1px solid var(--accent);
      border-left: 4px solid var(--accent);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin: var(--space-5) 0;
    }
    .connection-box h4 {
      font-family: var(--font-display);
      font-size: var(--text-base);
      font-weight: var(--weight-bold);
      color: var(--accent);
      margin-bottom: var(--space-3);
      margin-top: 0;
    }

    /* ── Summary Box ── */
    .summary-box {
      background: var(--surface-2);
      border: 1px solid var(--accent);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      margin-top: var(--space-5);
    }
    .summary-box h4 {
      font-size: var(--text-base);
      font-weight: var(--weight-semibold);
      color: var(--accent);
      margin-bottom: var(--space-3);
      margin-top: 0;
    }


    /* ─────────────────────────────────────────────────────────────────────
       INTERACTIVE 1 — Negative Feedback Loop Animation
       ───────────────────────────────────────────────────────────────────── */

    .feedback-anim {
      background: var(--surface-0);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin-top: var(--space-4);
    }
    .feedback-anim__diagram {
      width: 100%;
      overflow-x: auto;
    }
    .feedback-svg {
      width: 100%;
      max-width: 700px;
      display: block;
      margin: 0 auto;
    }
    .feedback-anim__desc {
      margin: var(--space-4) 0;
      padding: var(--space-4);
      background: var(--surface-2);
      border-radius: var(--radius-md);
      min-height: 80px;
    }
    .fb-step-indicator {
      display: flex;
      gap: var(--space-2);
      margin-bottom: var(--space-3);
    }
    .fb-step-dot {
      width: 10px;
      height: 10px;
      border-radius: var(--radius-full);
      background: var(--border-subtle);
      transition: background var(--transition-fast);
    }
    .fb-step-dot.is-active { background: var(--accent); }
    .fb-step-dot.is-done   { background: var(--green-vivid); opacity: 0.7; }
    .fb-desc-text {
      font-size: var(--text-base);
      color: var(--text-primary);
      font-weight: var(--weight-medium);
      margin-bottom: var(--space-2) !important;
    }
    .fb-example-text {
      font-size: var(--text-sm);
      color: var(--text-muted);
      margin-bottom: 0 !important;
      font-style: italic;
    }
    .feedback-anim__controls {
      display: flex;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-4);
    }
    .feedback-anim__selector {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
      padding-top: var(--space-4);
      border-top: 1px solid var(--border-subtle);
    }
    .fb-selector-label {
      font-size: var(--text-sm);
      color: var(--text-muted);
      font-family: var(--font-mono);
      flex-shrink: 0;
    }
    .fb-system-btns { display: flex; gap: var(--space-2); flex-wrap: wrap; }
    .fb-system-btn {
      padding: var(--space-2) var(--space-4);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-full);
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--text-secondary);
      cursor: pointer;
      transition: all var(--transition-fast);
    }
    .fb-system-btn:hover { border-color: var(--accent); color: var(--accent); }
    .fb-system-btn--active {
      background: rgba(0, 255, 136, 0.1);
      border-color: var(--accent);
      color: var(--accent);
    }


    /* ─────────────────────────────────────────────────────────────────────
       INTERACTIVE 2 — Set Point Visualiser
       ───────────────────────────────────────────────────────────────────── */

    .setpoint-vis {
      background: var(--surface-0);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin-top: var(--space-4);
    }
    .setpoint-vis__slider-row {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      flex-wrap: wrap;
      margin-bottom: var(--space-5);
    }
    .setpoint-vis__label {
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      color: var(--text-primary);
      white-space: nowrap;
    }
    .setpoint-vis__slider-wrap {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      flex: 1;
      min-width: 200px;
    }
    .setpoint-vis__min,
    .setpoint-vis__max {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      color: var(--text-muted);
      white-space: nowrap;
    }
    .setpoint-vis__slider {
      flex: 1;
      accent-color: var(--accent);
      cursor: pointer;
    }
    .setpoint-vis__current-val {
      font-size: var(--text-base);
      font-weight: var(--weight-bold);
      font-family: var(--font-mono);
      color: var(--fluoro-cyan);
      min-width: 4ch;
      text-align: right;
    }
    .setpoint-vis__display {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: var(--space-5);
      margin-bottom: var(--space-4);
    }
    @media (max-width: 600px) {
      .setpoint-vis__display { grid-template-columns: 1fr; }
    }
    .setpoint-vis__gauge-wrap { display: flex; flex-direction: column; align-items: center; }
    .gauge-label {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      color: var(--text-muted);
      margin-bottom: var(--space-3);
      text-align: center;
    }
    .gauge-container { width: 100%; }
    .gauge-track {
      position: relative;
      width: 36px;
      height: 220px;
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: 20px;
      margin: 0 auto var(--space-2);
      overflow: visible;
    }
    .gauge-fill {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--accent);
      border-radius: 0 0 18px 18px;
      transition: height 0.5s cubic-bezier(0.23, 1, 0.32, 1), background 0.5s;
    }
    .gauge-setpoint {
      position: absolute;
      left: -8px;
      right: -8px;
      height: 2px;
      background: var(--fluoro-pink);
      opacity: 0.8;
    }
    .gauge-zone {
      position: absolute;
      left: 0;
      right: 0;
    }
    .gauge-zone--low {
      bottom: 0;
      height: 10%;
      background: rgba(0, 150, 255, 0.15);
      border-radius: 0 0 18px 18px;
    }
    .gauge-zone--high {
      top: 0;
      height: 10%;
      background: rgba(255, 50, 50, 0.15);
      border-radius: 18px 18px 0 0;
    }
    .gauge-scale {
      display: flex;
      flex-direction: column-reverse;
      justify-content: space-between;
      height: 220px;
      font-size: 9px;
      font-family: var(--font-mono);
      color: var(--text-muted);
      padding: 2px 0;
    }
    .gauge-scale { display: none; } /* replaced by readout below */
    .gauge-readout {
      font-size: var(--text-xl);
      font-weight: var(--weight-bold);
      font-family: var(--font-mono);
      color: var(--accent);
      text-align: center;
      margin-top: var(--space-2);
      transition: color 0.4s;
    }
    .gauge-status {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      color: var(--text-muted);
      text-align: center;
      margin-top: var(--space-1);
      transition: color 0.4s;
    }
    .gauge-status--normal  { color: var(--green-vivid); }
    .gauge-status--warn    { color: #fbbf24; }
    .gauge-status--danger  { color: var(--fluoro-pink); }

    .setpoint-vis__responses {}
    .response-panel-title {
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      font-family: var(--font-display);
      color: var(--text-primary);
      margin-bottom: var(--space-3);
    }
    .response-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .response-item {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      padding: var(--space-3);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      transition: all var(--transition-fast);
    }
    .response-item--inactive { opacity: 0.4; }
    .response-item--active {
      opacity: 1;
      border-color: var(--accent);
      background: rgba(0, 255, 136, 0.06);
    }
    .response-item--active-cold {
      opacity: 1;
      border-color: var(--fluoro-cyan);
      background: rgba(0, 200, 255, 0.06);
    }
    .response-item__indicator {
      width: 10px;
      height: 10px;
      border-radius: var(--radius-full);
      background: var(--border-subtle);
      flex-shrink: 0;
      margin-top: 4px;
      transition: background var(--transition-fast);
    }
    .response-item--active .response-item__indicator { background: var(--accent); }
    .response-item--active-cold .response-item__indicator { background: var(--fluoro-cyan); }
    .response-item__text strong {
      display: block;
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      color: var(--text-primary);
      margin-bottom: 2px;
    }
    .response-item__text span {
      font-size: var(--text-xs);
      color: var(--text-muted);
    }
    .sp-warning {
      display: flex;
      gap: var(--space-3);
      align-items: flex-start;
      padding: var(--space-3) var(--space-4);
      background: rgba(255, 110, 199, 0.1);
      border: 1px solid var(--fluoro-pink);
      border-radius: var(--radius-md);
      margin-top: var(--space-3);
      font-size: var(--text-sm);
      color: var(--fluoro-pink);
    }
    .sp-warning svg { flex-shrink: 0; margin-top: 2px; color: var(--fluoro-pink); }
    .sp-warning p { margin: 0 !important; color: var(--fluoro-pink) !important; font-size: var(--text-sm) !important; }
    .setpoint-vis__explanation {
      padding: var(--space-3) var(--space-4);
      background: var(--surface-2);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
      min-height: 48px;
      transition: background 0.4s;
    }


    /* ─────────────────────────────────────────────────────────────────────
       System Overview Cards (Lesson 2)
       ───────────────────────────────────────────────────────────────────── */

    .systems-overview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: var(--space-5);
      margin: var(--space-5) 0;
    }
    .system-card {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      transition: border-color var(--transition-fast);
    }
    .system-card:hover { border-color: var(--accent); }
    .system-card--thermo { border-top: 3px solid var(--fluoro-pink); }
    .system-card--osmo   { border-top: 3px solid var(--fluoro-cyan); }
    .system-card--glucose{ border-top: 3px solid var(--green-vivid); }
    .system-card--ph     { border-top: 3px solid var(--accent); }
    .system-card__header {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
    }
    .system-card__icon { flex-shrink: 0; margin-top: 2px; }
    .system-card h3 {
      font-size: var(--text-base);
      font-weight: var(--weight-bold);
      font-family: var(--font-display);
      color: var(--text-primary);
      margin: 0 0 var(--space-1) !important;
    }
    .system-card__week {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      color: var(--text-muted);
    }
    .system-card__body { margin-bottom: var(--space-4); }
    .system-detail-row {
      display: flex;
      gap: var(--space-3);
      padding: var(--space-2) 0;
      border-bottom: 1px solid var(--border-subtle);
      font-size: var(--text-sm);
    }
    .system-detail-row:last-child { border-bottom: none; }
    .system-detail-label {
      color: var(--text-muted);
      width: 130px;
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      line-height: 1.5;
    }
    .system-detail-value { color: var(--text-secondary); flex: 1; font-size: var(--text-sm); line-height: 1.5; }
    .sp-highlight {
      color: var(--accent);
      font-weight: var(--weight-semibold);
      font-family: var(--font-mono);
    }
    .system-card__organisms {
      display: flex;
      align-items: flex-start;
      gap: var(--space-2);
      flex-wrap: wrap;
      margin-top: var(--space-3);
    }
    .org-label {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      color: var(--text-muted);
      white-space: nowrap;
    }
    .org-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }
    .org-chip {
      font-size: var(--text-xs);
      background: var(--surface-0);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-full);
      padding: 2px var(--space-3);
      color: var(--text-muted);
    }
    .system-card__exam-relevance {
      padding-top: var(--space-4);
      border-top: 1px solid var(--border-subtle);
    }
    .system-card__exam-relevance h4 {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      font-weight: var(--weight-semibold);
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0 0 var(--space-3) !important;
    }
    .system-card__exam-relevance .feature-list { margin-bottom: 0; }
    .system-card__exam-relevance .feature-list li { font-size: var(--text-sm); }


    /* ─────────────────────────────────────────────────────────────────────
       INTERACTIVE 3 — Matching Activity
       ───────────────────────────────────────────────────────────────────── */

    .matching-activity {
      margin-top: var(--space-4);
    }
    .matching-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
      margin-bottom: var(--space-4);
    }
    @media (max-width: 640px) {
      .matching-cols { grid-template-columns: 1fr; }
    }
    .matching-col__title {
      font-size: var(--text-xs);
      font-family: var(--font-mono);
      font-weight: var(--weight-semibold);
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: var(--space-3);
    }
    .match-card {
      display: block;
      width: 100%;
      text-align: left;
      padding: var(--space-4);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      font-family: var(--font-body);
      line-height: var(--leading-relaxed);
      cursor: pointer;
      transition: all var(--transition-fast);
      margin-bottom: var(--space-2);
    }
    .match-card:last-child { margin-bottom: 0; }
    .match-card:hover { border-color: var(--accent); background: var(--surface-3); }
    .match-card.is-selected {
      border-color: var(--fluoro-cyan);
      background: rgba(0, 200, 255, 0.08);
      color: var(--fluoro-cyan);
    }
    .match-card.is-matched {
      border-color: var(--green-vivid);
      background: rgba(0, 255, 136, 0.08);
      color: var(--green-vivid);
      cursor: default;
      pointer-events: none;
    }
    .match-card.is-wrong {
      border-color: var(--fluoro-pink);
      background: rgba(255, 110, 199, 0.08);
      animation: shake 0.4s ease;
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25%  { transform: translateX(-6px); }
      75%  { transform: translateX(6px); }
    }
    .matching-score {
      font-size: var(--text-sm);
      font-family: var(--font-mono);
      color: var(--text-muted);
      margin-bottom: var(--space-3);
    }
    .matching-complete {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-4);
      background: rgba(0, 255, 136, 0.08);
      border: 1px solid var(--green-vivid);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      color: var(--green-vivid);
      margin-bottom: var(--space-3);
    }


    /* ── Question Cards ── */
    .question-section { margin-top: var(--space-5); }
    .question-card {
      background: var(--surface-0);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      margin-bottom: var(--space-4);
      transition: border-color var(--transition-fast);
    }
    .question-card:focus-within { border-color: var(--accent); }
    .question-card__header {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-3);
    }
    .question-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: var(--radius-full);
      background: var(--accent);
      color: var(--surface-0);
      font-size: var(--text-sm);
      font-weight: var(--weight-bold);
      font-family: var(--font-display);
      flex-shrink: 0;
    }
    .question-text {
      font-size: var(--text-base);
      color: var(--text-primary);
      margin-bottom: var(--space-3);
    }
    .question-type-badge {
      font-size: var(--text-xs);
      font-weight: var(--weight-medium);
      padding: 2px var(--space-2);
      border-radius: var(--radius-sm);
      font-family: var(--font-mono);
    }
    .question-type-badge--short { background: rgba(0, 200, 255, 0.1); color: var(--fluoro-cyan); }
    .question-type-badge--multi { background: rgba(255, 100, 150, 0.1); color: var(--fluoro-pink); }
    .question-type-badge--long  { background: rgba(200, 100, 255, 0.1); color: var(--purple-light, #c084fc); }
    .sub-question { margin-bottom: var(--space-3); }
    .sub-label {
      display: block;
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--text-primary);
      margin-bottom: var(--space-2);
    }

    /* ── Answer Inputs ── */
    .answer-input {
      width: 100%;
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-sm);
      font-family: var(--font-body);
      color: var(--text-primary);
      line-height: var(--leading-relaxed);
      resize: vertical;
      transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .answer-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
    }
    .answer-input::placeholder { color: var(--text-muted); }
    .answer-input--short { min-height: 70px; }
    .answer-input--med   { min-height: 100px; }
    .answer-input--long  { min-height: 180px; }
    .answer-input--xl    { min-height: 220px; }

    /* ── Activity Card (model answers container) ── */
    .activity-card {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .activity-card h4 { margin-top: 0; }

    /* ── Reveal Buttons & Content ── */
    .reveal-section { margin-top: var(--space-3); }
    .reveal-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      color: var(--accent);
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      font-family: var(--font-display);
      cursor: pointer;
      transition: all var(--transition-fast);
    }
    .reveal-btn:hover { background: var(--surface-3); border-color: var(--accent); }
    .reveal-content { margin-top: var(--space-3); }
    .answer-card {
      background: var(--surface-2);
      border-left: 3px solid var(--accent);
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
      padding: var(--space-4);
      margin-bottom: var(--space-3);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
    }
    .answer-card p { font-size: var(--text-sm) !important; margin-bottom: var(--space-2) !important; }
