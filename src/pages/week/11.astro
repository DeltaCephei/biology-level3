      gap: var(--space-1);
      padding: var(--space-4);
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      text-decoration: none !important;
      color: var(--text-primary);
      transition: all var(--transition-fast);
      border-bottom: 1px solid var(--border-subtle) !important;
    }
    .system-card:hover {
      border-color: var(--accent) !important;
      background: var(--surface-1);
      transform: translateY(-2px);
    }
    .system-card__title {
      font-family: var(--font-display);
      font-weight: var(--weight-bold);
      font-size: var(--text-base);
      color: var(--text-primary);
    }
    .system-card__meta {
      font-size: var(--text-xs);
      color: var(--text-muted);
    }
    .system-card--locked {
      opacity: 0.45;
      cursor: not-allowed;
      pointer-events: none;
    }
    .system-card--locked .system-card__title { text-decoration: line-through; }

    /* ── AI split (allowed vs not allowed) ── */
    .ai-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
      margin: var(--space-4) 0 var(--space-5);
    }
    @media (max-width: 700px) {
      .ai-split { grid-template-columns: 1fr; }
    }
    .ai-split__allowed,
    .ai-split__not-allowed {
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .ai-split__allowed { border-top: 3px solid var(--accent); }
    .ai-split__not-allowed { border-top: 3px solid var(--fluoro-pink); }
    .ai-split h4 { margin-top: 0; margin-bottom: var(--space-3); font-size: var(--text-base); }
    .ai-split__allowed h4 { color: var(--accent); }
    .ai-split__not-allowed h4 { color: var(--fluoro-pink); }
    .ai-split ul { font-size: var(--text-sm); padding-left: var(--space-5); margin-bottom: 0; }

    /* ── AI examples ── */
    .ai-examples {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      margin: var(--space-4) 0 var(--space-5);
    }
    .ai-example {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: var(--space-4);
      align-items: start;
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      padding: var(--space-4);
    }
    @media (max-width: 700px) {
      .ai-example { grid-template-columns: 1fr; }
    }
    .ai-example--ok { border-left: 3px solid var(--accent); }
    .ai-example--not-ok { border-left: 3px solid var(--fluoro-pink); }
    .ai-example__tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-1) var(--space-3);
      font-family: var(--font-display);
      font-size: var(--text-xs);
      font-weight: var(--weight-bold);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      background: rgba(0, 255, 136, 0.15);
      color: var(--accent);
      border-radius: var(--radius-full);
      width: fit-content;
      height: fit-content;
    }
    .ai-example__tag--bad {
      background: rgba(255, 110, 199, 0.15);
      color: var(--fluoro-pink);
    }
    .ai-example__prompt {
      font-family: var(--font-mono);
      font-size: var(--text-sm) !important;
      color: var(--text-primary) !important;
      margin-bottom: var(--space-2) !important;
      font-style: italic;
    }
    .ai-example__why {
      font-size: var(--text-sm) !important;
      color: var(--text-secondary) !important;
      margin-bottom: 0 !important;
    }

    /* ── Step list (instructions) ── */
    .step-list {
      list-style: none !important;
      counter-reset: step-counter;
      padding-left: 0 !important;
      margin: var(--space-4) 0 !important;
    }
    .step-list li {
      counter-increment: step-counter;
      position: relative;
      padding-left: calc(var(--space-5) + 28px);
      font-size: var(--text-sm);
      margin-bottom: var(--space-3);
    }
    .step-list li::before {
      content: counter(step-counter);
      position: absolute;
      left: 0;
      top: 0;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent);
      color: var(--surface-0);
      font-family: var(--font-display);
      font-weight: var(--weight-bold);
      font-size: var(--text-sm);
      border-radius: var(--radius-full);
    }

    /* ── CTA button + row ── */
    .cta-row {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      flex-wrap: wrap;
      margin: var(--space-4) 0 var(--space-5);
    }
    .cta-button {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-5);
      background: var(--accent);
      color: var(--surface-0) !important;
      font-family: var(--font-display);
      font-weight: var(--weight-semibold);
      font-size: var(--text-sm);
      text-decoration: none !important;
      border-radius: var(--radius-md);
      transition: all var(--transition-fast);
      border-bottom: none !important;
    }
    .cta-button:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(0, 255, 136, 0.25);
    }
    .cta-row__meta {
      font-size: var(--text-xs);
      color: var(--text-muted);
      font-family: var(--font-mono);
    }

    /* ── Workflow steps ── */
    .workflow-steps {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      margin: var(--space-5) 0;
    }
    .workflow-step {
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: var(--space-4);
      align-items: start;
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      padding: var(--space-4);
    }
    .workflow-step__num {
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--fluoro-cyan);
      color: var(--surface-0);
      font-family: var(--font-display);
      font-weight: var(--weight-bold);
      border-radius: var(--radius-full);
    }
    .workflow-step h4 {
      margin: 0 0 var(--space-2) 0 !important;
      font-size: var(--text-base) !important;
    }
    .workflow-step p {
      font-size: var(--text-sm) !important;
      margin-bottom: 0 !important;
    }


    /* ─────────────────────────────────────────────────────────────────────
       SIDEBAR
       ───────────────────────────────────────────────────────────────────── */
    .week-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      position: sticky;
      top: calc(var(--space-8) + 60px);
    }
    .sidebar-card {
      background: var(--surface-1);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .sidebar-card h3 {
      font-size: var(--text-base);
      font-weight: var(--weight-bold);
      font-family: var(--font-display);
      color: var(--text-primary);
      margin-bottom: var(--space-4);
    }
    .sidebar-card--objectives { border-top: 3px solid var(--accent); }
    .sidebar-card--connection { border-top: 3px solid var(--fluoro-cyan); }
    .sidebar-card--deadline { border-top: 3px solid #fbbf24; }

    .sidebar-deadline {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      font-weight: var(--weight-bold);
      color: #fbbf24;
      margin-bottom: var(--space-1);
    }
    .sidebar-deadline-time {
      font-family: var(--font-mono);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin-bottom: var(--space-3);
    }

    .objectives-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .objectives-list li {
      position: relative;
      padding-left: var(--space-5);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
    }
    .objectives-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.5em;
      width: 8px;
      height: 8px;
      border: 1.5px solid var(--accent);
      border-radius: 2px;
    }

    /* ── Sidebar Links ── */
    .sidebar-links {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
      text-decoration: none;
      color: var(--text-secondary);
      font-size: var(--text-sm);
      transition: all var(--transition-fast);
    }
    .sidebar-link:hover { background: var(--surface-2); color: var(--text-primary); }
    .sidebar-link__icon { flex-shrink: 0; }

    .sidebar-text {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin-bottom: var(--space-2);
    }
    .sidebar-text--highlight {
      background: var(--surface-2);
      padding: var(--space-3);
      border-radius: var(--radius-sm);
      border-left: 3px solid var(--accent);
      margin-top: var(--space-3);
    }
  </style>


  <!-- ====================================================================
       Scripts
       ==================================================================== -->
  <script is:inline>

    /* IntersectionObserver — Fade-in-up animations */
    (function initObserver() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
    })();

  </script>

</BaseLayout>
